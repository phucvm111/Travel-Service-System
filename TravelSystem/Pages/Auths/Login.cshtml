@page
@model TravelSystem.Pages.Auths.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>

    body {
        background: url('/images/img_2.jpg') center/cover no-repeat fixed;
    }

    /* LOGIN LAYOUT */

    .login-page {
        min-height: 85vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-box {
        width: 850px;
        height: 500px;
        background: white;
        display: flex;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    /* FORM */

    .login-form {
        width: 50%;
        padding: 50px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .login-form h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #28a745;
        }

    /* INPUT */

    .form-group {
        margin-bottom: 20px;
        position: relative;
    }

    /* ICON MẮT */

    .password-box {
        position: relative;
    }

        .password-box input {
            padding-right: 45px;
        }

    .toggle-password {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #666;
        font-size: 16px;
    }

        .toggle-password:hover {
            color: #28a745;
        }

    /* IMAGE */

    .login-image {
        width: 50%;
        background: url('/images/14.jpg') center/cover no-repeat;
    }

    .form-control{
    font-size:16px;
    }

    .form-control:focus{
        font-size:16px;
    }

  
</style>


<div class="login-page">

    <div class="login-box">

        <!-- FORM -->
        <div class="login-form">

            <h2>Đăng nhập</h2>

            <form method="post">

                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Gmail"
                           class="form-control"
                           placeholder="Nhập email" />
                </div>

                <div class="form-group">

                    <label>Mật khẩu</label>

                    <div class="password-box">

                        <input asp-for="Password"
                               id="password"
                               type="password"
                               class="form-control"
                               placeholder="Nhập mật khẩu" />

                        <span class="toggle-password" onclick="togglePassword()">
                            <i id="eyeIcon" class="fa-solid fa-eye"></i>
                        </span>

                    </div>

                </div>

                <button class="btn btn-success w-100 mt-3">
                    Đăng nhập
                </button>

            </form>

            @if (Model.ErrorMessage != null)
            {
                <p class="text-danger text-center mt-3">
                    @Model.ErrorMessage
                </p>
            }

            <div class="text-center mt-3">
                Chưa có tài khoản?
                <a href="/Users/Registers/Register">Đăng ký</a>
            </div>

        </div>

        <!-- IMAGE -->
        <div class="login-image"></div>

    </div>

</div>


<script>

    function togglePassword(){

        var input = document.getElementById("password");
        var icon = document.getElementById("eyeIcon");

        if(input.type === "password"){
            input.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        }
        else{
            input.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }

    }

</script>