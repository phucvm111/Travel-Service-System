@page
@model TravelSystem.Pages.Payment.CancelPaymentModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Thanh toán bị hủy";
}

<div class="container-box shadow-sm" style="margin-top: 20px; margin-bottom:20px">
    <div class="text-center" >
        <div class="mb-4">
            <i class="fas fa-times-circle text-danger" style="font-size: 5rem;"></i>
        </div>
        <h2 class="text-danger fw-bold">Thanh Toán Đã Bị Hủy</h2>

        <div class="mt-4 p-4 bg-light rounded border">
            <p class="mb-2 fs-5">Bạn đã hủy giao dịch hoặc thoát khỏi trang thanh toán.</p>
            <p class="text-muted">Không có khoản thanh toán nào được thực hiện. Nếu bạn muốn tiếp tục trải nghiệm chuyến đi, vui lòng thực hiện đặt lại.</p>
        </div>

        <div class="mt-5 d-flex justify-content-center gap-3">
            <a asp-page="/Index" class="btn btn-primary px-5 py-2 fw-bold">
                <i class="fas fa-home me-2"></i>Quay về Trang chủ
            </a>
            @* Bạn có thể thêm nút quay lại ví nếu cần *@
            <a asp-page="/Users/Wallets/AmountToPay" class="btn btn-outline-secondary px-5 py-2">
                <i class="fas fa-wallet me-2"></i>Quay về ví
            </a>
        </div>
    </div>
</div>

    <style>
        body {
            background-color: #f8f9fa;
        }

        .container-box {
            max-width: 800px;
            margin: 0 auto;
            padding: 60px 40px;
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            min-height: 400px;
        }
    </style>
