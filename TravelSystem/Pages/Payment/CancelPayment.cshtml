@page
@model TravelSystem.Pages.Users.BookTours.CancelPaymentModel
@{
    ViewData["Title"] = "Thanh toán bị hủy";
}

<style>
    body {  background-color: #f8f9fa; }
    .container-box {
        max-width: 900px;
        margin: 50px auto;
        padding: 40px;
        background-color: white;
        border-radius: 12px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        text-align: center;
    }
    .title-cancel { font-size: 24px; font-weight: bold; color: #dc3545; margin-bottom: 20px; }
</style>

<div class="container-box">
    <div class="title-cancel">
        <i class="bi bi-x-circle-fill me-2"></i> Thanh Toán Đã Bị Hủy
    </div>
    <p class="lead">Bạn đã hủy giao dịch hoặc thoát khỏi trang thanh toán.</p>
    <p class="text-muted">Không có khoản thanh toán nào được thực hiện. Nếu bạn muốn tiếp tục đặt chuyến đi, vui lòng thực hiện lại quy trình đặt tour.</p>

    <div class="mt-4">
        <a asp-page="/Index" class="btn btn-primary px-5 py-2">Quay về Trang chủ</a>
    </div>
</div>