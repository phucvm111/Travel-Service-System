@page
@model PaymentWalletSuccessModel
@{
    ViewData["Title"] = "Wallet Recharge Success";
}

<link href="~/assets/css/bootstrap.min.css" rel="stylesheet" />
<link href="~/assets/css/style.css" rel="stylesheet" />

<style>
    body {
        background-color: #f8f9fa;
    }

    .container-box {
        max-width: 900px;
        margin: 100px auto;
        padding: 40px;
        background-color: white;
        border-radius: 20px;
        box-shadow: 0 0 20px rgba(0,0,0,0.1);
    }

    .title-success {
        font-size: 22px;
        font-weight: bold;
        color: #28a745;
        text-align: center;
        margin-bottom: 30px;
    }

    .btn-home {
        display: block;
        margin: 40px auto 0;
    }
</style>

<div class="container-box">

    <h3 class="text-center text-success mb-5">
        Bạn đã nạp tiền thành công
    </h3>

    <p>
        <strong>Tên:</strong>
        @Model.User.FirstName @Model.User.LastName
    </p>

    <div class="row">
        <div class="col-md-6">

            <p>
                <strong>Tổng tiền:</strong>
                @Model.PendingRecharge.Amount.ToString("N0") VNĐ
            </p>

        </div>
    </div>

    <div class="text-center mt-5">
        <a href="/Users/Wallets/WalletAmount"
           class="btn btn-outline-success px-5 py-2">
            Quay lại ví
        </a>
    </div>

</div>