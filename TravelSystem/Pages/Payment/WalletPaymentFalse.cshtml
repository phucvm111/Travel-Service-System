@page
@model TravelSystem.Pages.Wallet.DepositPaymentFalseModel
@{
    ViewData["Title"] = "Thanh toán bị hủy";
    Layout = "_Layout";
}

<div class="container-box shadow-sm mt-5">
    <div class="text-center">
        <div class="mb-4">
            <i class="fas fa-times-circle text-danger" style="font-size: 5rem;"></i>
        </div>
        <h2 class="text-danger fw-bold">Thanh Toán Đã Bị Hủy</h2>

        <div class="mt-4 p-3 bg-light rounded border">
            <p class="mb-2">Bạn đã chủ động hủy giao dịch hoặc thoát khỏi trang thanh toán.</p>
            @if (!string.IsNullOrEmpty(Model.PaymentCode))
            {
                <small class="text-secondary">Mã giao dịch: @Model.PaymentCode</small>
            }
        </div>

        <div class="mt-5 d-flex justify-content-center gap-3">
            <a asp-page="/Users/Wallets/AmountToPay" class="btn btn-outline-secondary px-4 py-2">
                <i class="fas fa-home me-2"></i> Quay về ví
            </a>
        </div>
    </div>
</div>


    <style>
        body {
            background-color: #f8f9fa;
        }

        .container-box {
            max-width: 700px;
            margin: 100px auto;
            padding: 50px;
            background-color: white;
            border-radius: 15px;
            min-height: 400px;
        }
    </style>
