@page
@model TravelSystem.Pages.Wallet.DepositSuccessModel
@{
    Layout = "_Layout";
}

<div class="container" style="max-width: 1140px; margin: 100px auto; padding: 40px; background-color: #fff; border-radius: 20px; box-shadow: 0 0 20px rgba(0,0,0,0.1);">
    <h3 class="text-center text-success mb-5">Bạn đã nạp thành công</h3>

    <div class="ms-4">
        <p><strong>Tên khách hàng:</strong> @Model.Customer?.FirstName @Model.Customer?.LastName</p>
        <p><strong>Email:</strong> @Model.Customer?.Gmail</p>
        <div class="row">
            <div class="col-md-6">
                <p><strong>Tổng tiền nạp:</strong> <span class="text-success fw-bold">@Model.Amount.ToString("N0") VNĐ</span></p>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <a asp-page="/Users/Wallets/AmountToPay" class="btn btn-outline-secondary px-4 py-2">
            <i class="fas fa-home me-2"></i> Quay về ví
        </a>
    </div>
</div>