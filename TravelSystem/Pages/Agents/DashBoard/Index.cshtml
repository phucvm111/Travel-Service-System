@page
@model TravelSystem.Pages.Agents.Dashboard.IndexModel

<div class="container-fluid p-4">
    <h1 class="mb-4 fw-bold">Bảng Điều Khiển Quản Trị</h1>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-primary text-uppercase small fw-semibold">Tổng số tour</div>
                        <div class="fs-2 fw-bold">@Model.TotalTours</div>
                    </div>
                    <i class="fa-solid fa-book fs-1 text-dark"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-success text-uppercase small fw-semibold">Số nhà hàng</div>
                        <div class="fs-2 fw-bold">@Model.TotalRestaurants</div>
                    </div>
                    <i class="fa-solid fa-utensils fs-1 text-dark"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-info text-uppercase small fw-semibold">Số giải trí</div>
                        <div class="fs-2 fw-bold">@Model.TotalEntertainments</div>
                    </div>
                    <i class="fa-solid fa-star fs-1 text-dark"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-warning text-uppercase small fw-semibold">Số khách sạn</div>
                        <div class="fs-2 fw-bold">@Model.TotalAccommodations</div>
                    </div>
                    <i class="fa-solid fa-hotel fs-1 text-dark"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-semibold text-primary">
            5 Đặt Tour Gần Đây Nhất
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Khách Hàng</th>
                            <th>Ngày Đặt</th>
                            <th>Tổng Giá</th>
                            <th>Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentBookings.Any())
                        {
                            foreach (var item in Model.RecentBookings)
                            {
                                <tr>
                                    <td>@item.CustomerName</td>
                                    <td>@item.BookDateText</td>
                                    <td>@String.Format("{0:N0} đ", item.TotalPrice)</td>
                                    <td>@item.StatusText</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center">Chưa có đơn đặt tour nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>