@page
@model TravelSystem.Pages.Agents.Room.IndexModel
@{
    ViewData["Title"] = "Quản lý phòng";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý phòng</h2>
        <a asp-page="/Agents/Accommodations/Index" class="btn btn-secondary">
            Quay lại khách sạn
        </a>
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <label class="form-label">Tìm theo loại phòng</label>
            <input asp-for="SearchRoomType" class="form-control" placeholder="Nhập loại phòng..." />
        </div>

        <div class="col-md-4">
            <label class="form-label">Lọc theo khách sạn</label>
            <select asp-for="FilterAccommodationId" class="form-select">
                <option value="">-- Tất cả khách sạn --</option>
                @foreach (var item in Model.AccommodationOptions)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">Lọc</button>
            <a asp-page="/Agents/Room/Index" class="btn btn-secondary">Xóa lọc</a>
        </div>
    </form>

    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>STT</th>
                <th>Mã phòng</th>
                <th>Mã khách sạn</th>
                <th>Tên khách sạn</th>
                <th>Loại phòng</th>
                <th>Số lượng phòng</th>
                <th>Giá phòng</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.RoomList.Any())
            {
                int stt = 1;
                foreach (var room in Model.RoomList)
                {
                    <tr>
                        <td>@stt</td>
                        <td>@room.RoomId</td>
                        <td>@room.AccommodationId</td>
                        <td>@room.Accommodation?.Name</td>
                        <td>@room.RoomTypes</td>
                        <td>@room.NumberOfRooms</td>
                        <td>@string.Format("{0:N0}", room.PriceOfRoom)</td>
                    </tr>
                    stt++;
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">Không có phòng nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>