@page
@model TravelSystem.Pages.Agents.Room.CreateModel
@{
    ViewData["Title"] = "Tạo phòng";
}

<div class="container-fluid p-4">
    <h2 class="mb-4">Tạo phòng</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="mb-3">
        <strong>Khách sạn:</strong> @Model.Accommodation?.Name
    </div>

    <form method="post">
        <input type="hidden" asp-for="Room.AccommodationId" />
        <div class="mb-3">
            <label asp-for="Room.RoomTypes" class="form-label">Loại phòng</label>
            <select asp-for="Room.RoomTypes" asp-items="Model.RoomTypeOptions" class="form-select">
                <option value="">-- Chọn loại phòng --</option>
            </select>
            <span asp-validation-for="Room.RoomTypes" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Room.NumberOfRooms" class="form-label">Số lượng phòng</label>
            <input asp-for="Room.NumberOfRooms" class="form-control" />
            <span asp-validation-for="Room.NumberOfRooms" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Room.PriceOfRoom" class="form-label">Giá phòng</label>
            <input asp-for="Room.PriceOfRoom" class="form-control" />
            <span asp-validation-for="Room.PriceOfRoom" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Tạo phòng</button>
        <a asp-page="/Agents/Accommodations/Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}