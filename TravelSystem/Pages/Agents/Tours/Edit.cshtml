@page
@model TravelSystem.Pages.Agents.Tours.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa thông tin Tour";
}

<style>
    body {
        background: #f4f6f9;
    }

    .create-box {
        max-width: 1200px;
        margin: 40px auto;
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .preview-box {
        width: 100%;
        height: 260px;
        border: 1px dashed #ccc;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: #fafafa;
        border-radius: 8px;
    }

    #preview {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .service-box {
        height: 150px;
    }

    .required {
        color: red;
        font-weight: bold;
    }

    .section-title {
        border-left: 4px solid #007bff;
        padding-left: 10px;
        margin: 20px 0;
        font-weight: bold;
    }
</style>

<div class="create-box">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Chỉnh Sửa Thông Tin Tour</h2>
        <a asp-page="./Index" class="btn btn-outline-secondary">← Quay lại</a>
    </div>

    <form method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Tour.TourId" />
        <input type="hidden" asp-for="ExistingImage" id="existingImageInput" />

        <div class="row">
            <div class="col-md-4">
                <label class="fw-bold">Hình ảnh Tour <span class="required">*</span></label>
                <div class="preview-box mb-2">
                    <img id="preview" src="/@Model.ExistingImage" style="@(string.IsNullOrEmpty(Model.ExistingImage) ? "display:none" : "")" />
                </div>
                <input type="file" asp-for="ImageFile" class="form-control" onchange="uploadTempImage(event)" />
            </div>

            <div class="col-md-8">
                <div class="mb-3">
                    <label class="fw-bold">Tên tour <span class="required">*</span></label>
                    <input asp-for="Tour.TourName" class="form-control" />
                    <span asp-validation-for="Tour.TourName" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Điểm bắt đầu <span class="required">*</span></label>
                        <select asp-for="Tour.StartPlace" class="form-control" id="startProvince" data-current="@Model.Tour?.StartPlace">
                            <option value="">Chọn tỉnh</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Điểm đến (Lọc dịch vụ) <span class="required">*</span></label>
                        <select asp-for="Tour.EndPlace" class="form-control" id="endPlaceSelect" onchange="filterServices()">
                            <option value="">Chọn điểm đến</option>
                            @foreach (var p in Model.EndPlaces)
                            {
                                <option value="@p" selected="@(Model.Tour.EndPlace == p ? "selected" : null)">@p</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <h4 class="section-title">Dịch vụ tại @Model.Tour.EndPlace</h4>
        <div class="row">
            <div class="col-md-4">
                <label>Nhà hàng</label>
                <select name="SelectedServices" multiple class="form-control service-box" id="restaurantSelect">
                    @foreach (var r in Model.Restaurants)
                    {
                        <option value="@r.ServiceId" data-address="@r.Service.Address" selected="@(Model.SelectedServices.Contains(r.ServiceId) ? "selected" : null)">@r.Service.ServiceName</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label>Khách sạn</label>
                <select name="SelectedServices" multiple class="form-control service-box" id="hotelSelect">
                    @foreach (var h in Model.Hotels)
                    {
                        <option value="@h.ServiceId" data-address="@h.Service.Address" selected="@(Model.SelectedServices.Contains(h.ServiceId) ? "selected" : null)">@h.Service.ServiceName</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label>Giải trí</label>
                <select name="SelectedServices" multiple class="form-control service-box" id="entertainmentSelect">
                    @foreach (var e in Model.Entertainments)
                    {
                        <option value="@e.ServiceId" data-address="@e.Service.Address" selected="@(Model.SelectedServices.Contains(e.ServiceId) ? "selected" : null)">@e.Service.ServiceName</option>
                    }
                </select>
            </div>
        </div>

        <div class="mt-4">
            <label class="fw-bold">Lịch trình chi tiết <span class="required">*</span></label>
            <textarea asp-for="Tour.TourSchedule" class="form-control" rows="5"></textarea>
        </div>

        <div class="text-center mt-4">
            <button type="submit" class="btn btn-success btn-lg px-5">Cập Nhật Tour</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function uploadTempImage(event) {
            var reader = new FileReader();
            reader.onload = function(){
                var output = document.getElementById('preview');
                output.src = reader.result;
                output.style.display = 'block';
            };
            reader.readAsDataURL(event.target.files[0]);
        }

        function filterServices() {
            var place = document.getElementById("endPlaceSelect").value;
            ["restaurantSelect", "hotelSelect", "entertainmentSelect"].forEach(id => {
                Array.from(document.getElementById(id).options).forEach(opt => {
                    opt.style.display = (!place || opt.dataset.address === place) ? "" : "none";
                });
            });
        }

        fetch("https://provinces.open-api.vn/api/p/").then(r => r.json()).then(data => {
            var s = document.getElementById("startProvince");
            data.forEach(p => {
                var o = new Option(p.name, p.name);
                if(p.name === s.dataset.current) o.selected = true;
                s.add(o);
            });
        });

        document.addEventListener("DOMContentLoaded", filterServices);
    </script>
}