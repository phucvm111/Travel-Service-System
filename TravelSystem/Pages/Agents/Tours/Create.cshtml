@page
@model TravelSystem.Pages.Agents.Tours.CreateModel

<style>
    body {
        background: #f4f6f9;
    }

    .create-box {
        max-width: 1200px;
        margin: 40px auto;
        background: white;
        padding: 40px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    h2 {
        color: #28A745;
        text-align: center;
        margin-bottom: 30px;
    }

    /* ── Layout hình ảnh + form cơ bản ── */
    .flex-top {
        display: flex;
        gap: 30px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .image-column {
        flex: 0 0 420px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .image-preview {
        width: 400px;
        height: 260px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px dashed #ccc;
        background: #fafafa;
    }

    .form-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    /* ── 2 / 3 cột trong hàng ── */
    .row-2col {
        display: flex;
        gap: 16px;
    }

        .row-2col > .col,
        .row-3col > .col {
            flex: 1;
        }

    .row-3col {
        display: flex;
        gap: 16px;
    }

    /* ── Dịch vụ ── */
    .service-row {
        display: flex;
        gap: 16px;
        margin-bottom: 8px;
    }

    .service-col {
        flex: 1;
    }

    .service-select {
        height: 110px;
    }

    /* ── Nút xóa chọn ── */
    .btn-clear {
        margin-top: 6px;
        font-size: 13px;
        padding: 5px 14px;
        background: #FFC107;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        color: #000;
        font-weight: 500;
    }

        .btn-clear:hover {
            background: #e0a800;
        }

    /* ── Lỗi ── */
    .field-error {
        color: #dc3545;
        font-size: 13px;
        margin-top: 4px;
        display: block;
    }

    .required {
        color: red;
        font-weight: bold;
    }
</style>

<div class="create-box">
    <h2>Tạo Tour</h2>

    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-page="./Index" class="btn btn-outline-secondary">← Quay lại</a>
    </div>

    @* Lỗi chung (nếu có) *@
    @foreach (var err in ViewData.ModelState[""]?.Errors
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.ModelBinding.ModelError>())
    {
        <div class="alert alert-danger">@err.ErrorMessage</div>
    }

    <div id="formWrapper">
        <form method="post" enctype="multipart/form-data" id="tourForm" novalidate>

            @Html.AntiForgeryToken()

            @* Hidden fields cho giá, số lượng (giá trị thô không format) *@
            <input type="hidden" name="AdultPriceRaw" id="adultPriceHidden" value="@Model.AdultPriceRaw" />
            <input type="hidden" name="ChildrenPriceRaw" id="childPriceHidden" value="@Model.ChildrenPriceRaw" />
            <input type="hidden" name="QuantityRaw" id="quantityHidden" value="@Model.QuantityRaw" />

            <input type="hidden" name="ExistingImage" id="existingImageHidden"
                   value="@Model.ExistingImage" />

            @* ════════════════════════════════════════════════════════════
               PHẦN 1: Ảnh + thông tin cơ bản
               ════════════════════════════════════════════════════════════ *@
            <div class="flex-top">

                <div class="image-column">
                    @if (!string.IsNullOrEmpty(Model.ExistingImage))
                    {
                        @* Có ảnh cũ → hiện luôn (giống JSP: not empty sessionScope.imagePath) *@
                        <img id="preview" class="image-preview"
                             src="/@Model.ExistingImage" alt="Ảnh xem trước" />
                    }
                    else
                    {
                        @* Chưa có ảnh → hiện placeholder *@
                        <img id="preview" class="image-preview"
                             src="~/assets/img/placeholder.jpg"
                             onerror="this.style.visibility='hidden'"
                             alt="Ảnh xem trước" />
                    }
                    <br />
                    <input type="file" name="ImageFile" id="imageFileInput"
                           class="form-control mt-2" accept="image/*"
                           onchange="onImageChange(event)" />
                    @if (ViewData.ModelState["ImageFile"]?.Errors.Count > 0)
                    {
                        <span class="field-error">
                            @ViewData.ModelState["ImageFile"].Errors[0].ErrorMessage
                        </span>
                    }
                </div>

                @* Cột form thông tin cơ bản *@
                <div class="form-column">

                    @* Tên tour *@
                    <div class="form-group">
                        <label>Tên tour <span class="required">*</span></label>
                        <input type="text" name="Tour.TourName" class="form-control"
                               value="@Model.Tour.TourName"
                               placeholder="Nhập tên tour" />
                        @if (ViewData.ModelState["Tour.TourName"]?.Errors.Count > 0)
                        {
                            <span class="field-error">
                                @ViewData.ModelState["Tour.TourName"].Errors[0].ErrorMessage
                            </span>
                        }
                    </div>

                    @* Điểm đi / Điểm đến *@
                    <div class="row-2col">
                        <div class="col">
                            <label>Điểm bắt đầu <span class="required">*</span></label>
                            <select name="Tour.StartPlace" class="form-control" id="startProvince"
                                    data-current="@Model.Tour.StartPlace">
                                <option value="">Chọn tỉnh/thành</option>
                            </select>
                            @if (ViewData.ModelState["Tour.StartPlace"]?.Errors.Count > 0)
                            {
                                <span class="field-error">
                                    @ViewData.ModelState["Tour.StartPlace"].Errors[0].ErrorMessage
                                </span>
                            }
                        </div>
                        <div class="col">
                            <label>Điểm đến <span class="required">*</span></label>
                            <select name="Tour.EndPlace" class="form-control" id="endPlaceSelect"
                                    onchange="filterServices()">
                                <option value="">Chọn điểm đến</option>
                                @foreach (var p in Model.EndPlaces)
                                {
                                    if (Model.Tour.EndPlace == p)
                                    {
                                        <option value="@p" selected>@p</option>
                                    }
                                    else
                                    {
                                        <option value="@p">@p</option>
                                    }
                                }
                            </select>
                            @if (ViewData.ModelState["Tour.EndPlace"]?.Errors.Count > 0)
                            {
                                <span class="field-error">
                                    @ViewData.ModelState["Tour.EndPlace"].Errors[0].ErrorMessage
                                </span>
                            }
                        </div>
                    </div>

                    @* Ngày bắt đầu / Ngày kết thúc *@
                    <div class="row-2col">
                        <div class="col">
                            <label>Ngày bắt đầu <span class="required">*</span></label>
                            <input type="date" name="Tour.StartDay" class="form-control" id="startDay"
                                   value="@Model.Tour.StartDay?.ToString("yyyy-MM-dd")" />
                            @if (ViewData.ModelState["Tour.StartDay"]?.Errors.Count > 0)
                            {
                                <span class="field-error">
                                    @ViewData.ModelState["Tour.StartDay"].Errors[0].ErrorMessage
                                </span>
                            }
                        </div>
                        <div class="col">
                            <label>Ngày kết thúc <span class="required">*</span></label>
                            <input type="date" name="Tour.EndDay" class="form-control" id="endDay"
                                   value="@Model.Tour.EndDay?.ToString("yyyy-MM-dd")" />
                            @if (ViewData.ModelState["Tour.EndDay"]?.Errors.Count > 0)
                            {
                                <span class="field-error">
                                    @ViewData.ModelState["Tour.EndDay"].Errors[0].ErrorMessage
                                </span>
                            }
                        </div>
                    </div>

                    @* Giá người lớn / Giá trẻ em / Số lượng *@
                    <div class="row-3col">
                        <div class="col">
                            <label>Giá người lớn <span class="required">*</span></label>
                            <input type="text" id="adultPriceDisplay" class="form-control"
                                   autocomplete="off" placeholder="Nhập giá"
                                   value="@FormatPrice(Model.AdultPriceRaw)" />
                            @if (ViewData.ModelState["AdultPriceRaw"]?.Errors.Count > 0)
                            {
                                <span class="field-error">
                                    @ViewData.ModelState["AdultPriceRaw"].Errors[0].ErrorMessage
                                </span>
                            }
                        </div>
                        <div class="col">
                            <label>Giá trẻ em <span class="required">*</span></label>
                            <input type="text" id="childPriceDisplay" class="form-control"
                                   autocomplete="off" placeholder="Nhập giá"
                                   value="@FormatPrice(Model.ChildrenPriceRaw)" />
                            @if (ViewData.ModelState["ChildrenPriceRaw"]?.Errors.Count > 0)
                            {
                                <span class="field-error">
                                    @ViewData.ModelState["ChildrenPriceRaw"].Errors[0].ErrorMessage
                                </span>
                            }
                        </div>
                        <div class="col">
                            <label>Số lượng <span class="required">*</span></label>
                            <input type="text" id="quantityDisplay" class="form-control"
                                   autocomplete="off" placeholder="Nhập số lượng"
                                   value="@Model.QuantityRaw" />
                            @if (ViewData.ModelState["QuantityRaw"]?.Errors.Count > 0)
                            {
                                <span class="field-error">
                                    @ViewData.ModelState["QuantityRaw"].Errors[0].ErrorMessage
                                </span>
                            }
                        </div>
                    </div>

                </div>
            </div>

            @* ════════════════════════════════════════════════════════════
               PHẦN 2: Dịch vụ 
               ════════════════════════════════════════════════════════════ *@
            <h5 class="mt-2 mb-2">Dịch vụ tour</h5>
            <div class="service-row">

                <div class="service-col">
                    <label>Nhà hàng</label>
                    <input type="hidden" name="SelectedRestaurants" value="" />
                    <select name="SelectedRestaurants" multiple
                            class="form-control service-select" id="restaurantSelect">
                        @foreach (var r in Model.Restaurants)
                        {
                            if (Model.SelectedRestaurants.Contains(r.RestaurantId))
                            {
                                <option value="@r.RestaurantId" data-address="@r.Address" selected>
                                    @r.Name
                                </option>
                            }
                            else
                            {
                                <option value="@r.RestaurantId" data-address="@r.Address">
                                    @r.Name
                                </option>
                            }
                        }
                    </select>
                    <button type="button" class="btn-clear"
                            onclick="clearSelect('restaurantSelect')">
                        Xóa lựa chọn
                    </button>
                </div>

                <div class="service-col">
                    <label>Khách sạn</label>
                    <input type="hidden" name="SelectedHotels" value="" />
                    <select name="SelectedHotels" multiple
                            class="form-control service-select" id="hotelSelect">
                        @foreach (var h in Model.Hotels)
                        {
                            if (Model.SelectedHotels.Contains(h.AccommodationId))
                            {
                                <option value="@h.AccommodationId" data-address="@h.Address" selected>
                                    @h.Name
                                </option>
                            }
                            else
                            {
                                <option value="@h.AccommodationId" data-address="@h.Address">
                                    @h.Name
                                </option>
                            }
                        }
                    </select>
                    <button type="button" class="btn-clear"
                            onclick="clearSelect('hotelSelect')">
                        Xóa lựa chọn
                    </button>
                </div>

                <div class="service-col">
                    <label>Giải trí</label>
                    <input type="hidden" name="SelectedEntertainments" value="" />
                    <select name="SelectedEntertainments" multiple
                            class="form-control service-select" id="entertainmentSelect">
                        @foreach (var e in Model.Entertainments)
                        {
                            if (Model.SelectedEntertainments.Contains(e.EntertainmentId))
                            {
                                <option value="@e.EntertainmentId" data-address="@e.Address" selected>
                                    @e.Name
                                </option>
                            }
                            else
                            {
                                <option value="@e.EntertainmentId" data-address="@e.Address">
                                    @e.Name
                                </option>
                            }
                        }
                    </select>
                    <button type="button" class="btn-clear"
                            onclick="clearSelect('entertainmentSelect')">
                        Xóa lựa chọn
                    </button>
                </div>

            </div>

            @* ════════════════════════════════════════════════════════════
               PHẦN 3: Textarea chi tiết
               ════════════════════════════════════════════════════════════ *@
            <div class="form-group mt-3">
                <label>Giới thiệu tour <span class="required">*</span></label>
                <textarea name="Tour.TourIntroduce" class="form-control" rows="4"
                          placeholder="Giới thiệu về tour">@Model.Tour.TourIntroduce</textarea>
                @if (ViewData.ModelState["Tour.TourIntroduce"]?.Errors.Count > 0)
                {
                    <span class="field-error">
                        @ViewData.ModelState["Tour.TourIntroduce"].Errors[0].ErrorMessage
                    </span>
                }
            </div>

            <div class="form-group mt-2">
                <label>Lịch trình tour <span class="required">*</span></label>
                <textarea name="Tour.TourSchedule" class="form-control" rows="5"
                          placeholder="Lịch trình chi tiết">@Model.Tour.TourSchedule</textarea>
                @if (ViewData.ModelState["Tour.TourSchedule"]?.Errors.Count > 0)
                {
                    <span class="field-error">
                        @ViewData.ModelState["Tour.TourSchedule"].Errors[0].ErrorMessage
                    </span>
                }
            </div>

            <div class="form-group mt-2">
                <label>Bao gồm <span class="required">*</span></label>
                <textarea name="Tour.TourInclude" class="form-control" rows="3"
                          placeholder="Những gì đã bao gồm trong tour">@Model.Tour.TourInclude</textarea>
                @if (ViewData.ModelState["Tour.TourInclude"]?.Errors.Count > 0)
                {
                    <span class="field-error">
                        @ViewData.ModelState["Tour.TourInclude"].Errors[0].ErrorMessage
                    </span>
                }
            </div>

            <div class="form-group mt-2">
                <label>Không bao gồm <span class="required">*</span></label>
                <textarea name="Tour.TourNonInclude" class="form-control" rows="3"
                          placeholder="Những gì không bao gồm">@Model.Tour.TourNonInclude</textarea>
                @if (ViewData.ModelState["Tour.TourNonInclude"]?.Errors.Count > 0)
                {
                    <span class="field-error">
                        @ViewData.ModelState["Tour.TourNonInclude"].Errors[0].ErrorMessage
                    </span>
                }
            </div>

            <br />
            <div class="d-flex justify-content-center">
                <button type="submit" class="btn btn-success"
                        style="width:200px; padding:10px 0">
                    Tạo Tour
                </button>
            </div>

        </form>
    </div>
</div>

@* ════════════════════════════════════════════════════════════════════════
   Helper: format giá VN để hiện vào display input sau khi reload trang
   ════════════════════════════════════════════════════════════════════════ *@
@functions {
    string FormatPrice(string? raw)
    {
        if (string.IsNullOrEmpty(raw)) return "";
        // Bỏ mọi ký tự không phải số rồi format N0 theo vi-VN
        var digits = new string(raw.Where(char.IsDigit).ToArray());
        if (!long.TryParse(digits, out var num)) return raw;
        return num.ToString("N0", new System.Globalization.CultureInfo("vi-VN"));
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
    <script>

        // ── Preview ảnh khi chọn file mới ────────────────────────────────────
        function onImageChange(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                const img = document.getElementById("preview");
                img.src = e.target.result;
                img.style.visibility = "visible";
                // Khi chọn ảnh mới thì xóa giá trị ảnh cũ
                document.getElementById("existingImageHidden").value = "";
            };
            reader.readAsDataURL(file);
        }

        // ── Format tiền VND ───────────────────────────────────────────────────
        function formatMoney(raw) {
            if (!raw) return "";
            return Number(raw).toLocaleString("vi-VN");
        }

        function setupMoneyInput(displayId, hiddenId) {
            const display = document.getElementById(displayId);
            const hidden  = document.getElementById(hiddenId);
            if (!display || !hidden) return;

            display.addEventListener("input", function () {
                const pos    = this.selectionStart;
                const oldLen = this.value.length;
                const raw    = this.value.replace(/\D/g, "");
                if (raw === "") { this.value = ""; hidden.value = ""; return; }
                this.value   = formatMoney(raw);
                hidden.value = raw;
                const newPos = pos + (this.value.length - oldLen);
                this.setSelectionRange(newPos, newPos);
            });
        }

        function setupIntInput(displayId, hiddenId) {
            const display = document.getElementById(displayId);
            const hidden  = document.getElementById(hiddenId);
            if (!display || !hidden) return;
            display.addEventListener("input", function () {
                const raw    = this.value.replace(/\D/g, "");
                this.value   = raw;
                hidden.value = raw;
            });
        }

        setupMoneyInput("adultPriceDisplay", "adultPriceHidden");
        setupMoneyInput("childPriceDisplay",  "childPriceHidden");
        setupIntInput("quantityDisplay",      "quantityHidden");

        // ── Min date = ngày mai ───────────────────────────────────────────────
        (function () {
            const sd = document.getElementById("startDay");
            const ed = document.getElementById("endDay");
            if (!sd || !ed) return;
            const tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);
            const minDate = tomorrow.toISOString().split("T")[0];
            sd.setAttribute("min", minDate);
            ed.setAttribute("min", minDate);
        })();

        const startDayEl = document.getElementById("startDay");
        if (startDayEl) {
            startDayEl.addEventListener("change", function () {
                const ed = document.getElementById("endDay");
                ed.setAttribute("min", this.value);
                if (ed.value && ed.value < this.value) ed.value = this.value;
            });
        }

        // ── Load tỉnh/thành  ─────────────────────
        fetch("https://provinces.open-api.vn/api/p/")
            .then(function (res) { return res.json(); })
            .then(function (data) {
                const select  = document.getElementById("startProvince");
                if (!select) return;
                const current = select.getAttribute("data-current") || "";
                data.forEach(function (p) {
                    const opt   = document.createElement("option");
                    opt.value   = p.name;
                    opt.text    = p.name;
                    if (p.name === current) opt.selected = true;
                    select.appendChild(opt);
                });
            })
            .catch(function () {
                const select = document.getElementById("startProvince");
                if (select) {
                    const opt = document.createElement("option");
                    opt.text  = "Lỗi tải danh sách tỉnh/thành";
                    select.appendChild(opt);
                }
            });

        // ── Filter dịch vụ theo điểm đến ─────────────────────────────────────
        function filterServices() {
            const ep = document.getElementById("endPlaceSelect");
            if (!ep) return;
            const selected = ep.value;
            filterSelect("restaurantSelect",   selected);
            filterSelect("hotelSelect",         selected);
            filterSelect("entertainmentSelect", selected);
        }

        function filterSelect(selectId, address) {
            const select = document.getElementById(selectId);
            if (!select) return;
            Array.from(select.options).forEach(function (opt) {
                const optAddr = opt.getAttribute("data-address") || "";
                if (!address || optAddr === address) {
                    opt.style.display = "";
                } else {
                    opt.style.display = "none";
                    opt.selected      = false;
                }
            });
        }

        // ── Xóa lựa chọn select ──────────────
        function clearSelect(selectId) {
            const select = document.getElementById(selectId);
            if (!select) return;
            Array.from(select.options).forEach(function (opt) { opt.selected = false; });
        }

        // ── DOMContentLoaded: sync hidden fields & filter dịch vụ ────────────
        document.addEventListener("DOMContentLoaded", function () {
            // Filter dịch vụ theo điểm đến hiện tại
            filterServices();

            // Sync hidden fields khi trang reload sau lỗi
            const adultDisplay = document.getElementById("adultPriceDisplay");
            const childDisplay = document.getElementById("childPriceDisplay");
            const qtyDisplay   = document.getElementById("quantityDisplay");

            if (adultDisplay && adultDisplay.value)
                document.getElementById("adultPriceHidden").value =
                    adultDisplay.value.replace(/\./g, "").replace(/,/g, "");

            if (childDisplay && childDisplay.value)
                document.getElementById("childPriceHidden").value =
                    childDisplay.value.replace(/\./g, "").replace(/,/g, "");

            if (qtyDisplay && qtyDisplay.value)
                document.getElementById("quantityHidden").value =
                    qtyDisplay.value.replace(/\D/g, "");
        });
    </script>
}
