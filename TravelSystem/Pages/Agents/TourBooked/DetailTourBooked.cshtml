@page
@model TravelSystem.Pages.Agents.Tours.DetailTourBookedModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết chuyến đi được đặt";
}

<style>
    body {
        /* Nền ảnh overlay giống bản Java */
        background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('/assets/img/background/BackgroundTourBooked.png') no-repeat center center fixed;
        background-size: cover;
        color: #fff !important;
    }

    .detail-container {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        margin-top: 50px;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .info-label {
        font-weight: 600;
        color: #ffca2c; /* Màu vàng Gold cho label nổi bật trên nền tối */
        width: 180px;
        display: inline-block;
    }

    .info-value {
        color: #fff;
    }

    .tour-img-detail {
        width: 100%;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        object-fit: cover;
        max-height: 400px;
    }

    .btn-back {
        border: 2px solid #fff;
        color: #fff;
        padding: 10px 25px;
        border-radius: 50px;
        transition: 0.3s;
        text-decoration: none;
    }

        .btn-back:hover {
            background: #fff;
            color: #000 !important;
        }

    /* Fix màu chữ cho các thẻ heading */
    h1, h3, h5, b, span {
        color: #fff !important;
    }
</style>

<div class="container pb-5">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mt-5">@Model.ErrorMessage</div>
    }
    else
    {
        <div class="detail-container shadow-lg">
            <div class="row mb-4">
                <div class="col-12 text-center">
                    <h1 class="display-5 fw-bold">Chi tiết đơn đặt tour</h1>
                    <p class="text-white-50">Mã đơn hàng: #@Model.BookDetail.BookCode</p>
                </div>
            </div>

            <div class="row g-5">
                <div class="col-lg-5">
                    <img src="~/@(Model.BookDetail.Tour?.Image ?? "images/no-image.png")"
                         class="tour-img-detail"
                         alt="Tour Image"
                         onerror="this.src='/images/no-image.png'">

                    <div class="mt-4 p-3 rounded bg-white bg-opacity-10">
                        <h5><i class="bi bi-info-circle me-2"></i>Ghi chú từ khách hàng:</h5>
                        <p class="mb-0 italic text-white-50">
                            "@(string.IsNullOrEmpty(Model.BookDetail.Note) ? "Không có ghi chú nào." : Model.BookDetail.Note)"
                        </p>
                    </div>
                </div>

                <div class="col-lg-7">
                    <h3 class="text-warning mb-4 border-bottom pb-2">@Model.BookDetail.Tour?.TourName</h3>

                    <div class="mb-3">
                        <span class="info-label">Khách hàng:</span>
                        <span class="info-value">@Model.BookDetail.FirstName @Model.BookDetail.LastName</span>
                    </div>

                    <div class="mb-3">
                        <span class="info-label">Ngày đặt:</span>
                        <span class="info-value">@Model.BookDetail.BookDate?.ToString("dd/MM/yyyy")</span>
                    </div>

                    <div class="mb-3">
                        <span class="info-label">Số điện thoại:</span>
                        <span class="info-value">@Model.BookDetail.Phone</span>
                    </div>

                    <div class="mb-3">
                        <span class="info-label">Email:</span>
                        <span class="info-value">@Model.BookDetail.Gmail</span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <span class="info-label w-auto">Người lớn:</span>
                            <span class="info-value ms-2">@Model.BookDetail.NumberAdult</span>
                        </div>
                        <div class="col-6">
                            <span class="info-label w-auto">Trẻ em:</span>
                            <span class="info-value ms-2">@Model.BookDetail.NumberChildren</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <span class="info-label">Voucher sử dụng:</span>
                        <span class="badge bg-success">@(Model.BookDetail.Voucher?.VoucherCode ?? "Không dùng mã")</span>
                    </div>

                    <div class="mb-4 p-3 rounded bg-danger bg-opacity-25 border border-danger">
                        <span class="info-label h4 mb-0">Tổng tiền:</span>
                        <span class="h3 fw-bold text-white ms-2">@((Model.BookDetail.TotalPrice ?? 0).ToString("N0")) VNĐ</span>
                    </div>

                    <div class="mt-5">
                        <a asp-page="./ManageTourBooked" class="btn-back">
                            <i class="bi bi-arrow-left me-2"></i> Quay lại danh sách
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>