@page "{id:int}"
@model TravelSystem.Pages.Agents.Entertainments.EditModel
@{
    ViewData["Title"] = "Cập nhật dịch vụ giải trí";
}

<h2 class="mb-4">Cập nhật dịch vụ giải trí</h2>

<form method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Input.EntertainmentId" />
    <input type="hidden" asp-for="Input.ServiceId" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-6">
            <div class="border p-3 text-center" style="min-height:320px;">
                <p><strong>Xem trước ảnh</strong></p>

                @if (!string.IsNullOrEmpty(Model.CurrentImage))
                {
                    <img id="previewImage"
                         src="~/@Model.CurrentImage"
                         alt="Entertainment Image"
                         style="max-width:100%; max-height:250px; object-fit:cover;" />
                }
                else
                {
                    <img id="previewImage"
                         src="https://via.placeholder.com/400x250?text=H%C3%A3y+ch%E1%BB%8Dn+%E1%BA%A3nh"
                         alt="Preview"
                         style="max-width:100%; max-height:250px; object-fit:cover;" />
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Chọn ảnh dịch vụ</label>
                <input asp-for="UploadImage" type="file" class="form-control" accept="image/*" onchange="previewFile(event)" />
            </div>

            <div class="mb-3">
                <label asp-for="Input.Name" class="form-label">Tên dịch vụ *</label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Type" class="form-label">Loại giải trí *</label>
                <select asp-for="Input.Type" asp-items="Model.EntertainmentTypes" class="form-select">
                    <option value="">-- Chọn loại giải trí --</option>
                </select>
                <span asp-validation-for="Input.Type" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.City" class="form-label">Chọn tỉnh / thành phố *</label>
                <select asp-for="Input.City" asp-items="Model.Cities" class="form-select">
                    <option value="">-- Chọn tỉnh / thành phố --</option>
                </select>
                <span asp-validation-for="Input.City" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Phone" class="form-label">Số điện thoại *</label>
                <input asp-for="Input.Phone" class="form-control" />
                <span asp-validation-for="Input.Phone" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Rate" class="form-label">Đánh giá (Thang điểm 10)</label>
                <input asp-for="Input.Rate" class="form-control" type="number" min="0" max="10" step="0.1" />
                <span asp-validation-for="Input.Rate" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.TimeOpen" class="form-label">Thời gian mở cửa *</label>
                    <input asp-for="Input.TimeOpen" class="form-control" type="time" />
                    <span asp-validation-for="Input.TimeOpen" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Input.TimeClose" class="form-label">Thời gian đóng cửa *</label>
                    <input asp-for="Input.TimeClose" class="form-control" type="time" />
                    <span asp-validation-for="Input.TimeClose" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Ngày mở cửa trong tuần *</label>
                <select asp-for="Input.DayOfWeekOpen" class="form-select" multiple size="7">
                    <option value="Thứ 2">Thứ 2</option>
                    <option value="Thứ 3">Thứ 3</option>
                    <option value="Thứ 4">Thứ 4</option>
                    <option value="Thứ 5">Thứ 5</option>
                    <option value="Thứ 6">Thứ 6</option>
                    <option value="Thứ 7">Thứ 7</option>
                    <option value="Chủ nhật">Chủ nhật</option>
                </select>
                <span asp-validation-for="Input.DayOfWeekOpen" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.TicketPrice" class="form-label">Giá vé *</label>
                <input asp-for="Input.TicketPrice" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Input.TicketPrice" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label">Mô tả dịch vụ *</label>
                <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Status" class="form-label">Trạng thái *</label>
                <select asp-for="Input.Status" asp-items="Model.StatusList" class="form-select">
                    <option value="">-- Chọn trạng thái --</option>
                </select>
                <span asp-validation-for="Input.Status" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Cập nhật</button>
                <a asp-page="./Index" class="btn btn-secondary">Hủy bỏ</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewFile(event) {
            const input = event.target;
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewImage').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}