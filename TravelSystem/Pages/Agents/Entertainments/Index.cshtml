@page
@model TravelSystem.Pages.Agents.Entertainments.IndexModel
@{
    ViewData["Title"] = "Danh sách giải trí";
    int stt = 1;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Danh sách giải trí</h2>
    <a asp-page="./Create" class="btn btn-success">Thêm giải trí</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<form method="get" class="row mb-3">
    <div class="col-md-4">
        <input asp-for="SearchTerm" class="form-control" placeholder="Tìm giải trí..." />
    </div>

    <div class="col-md-3">
        <select asp-for="StatusFilter" class="form-select">
            <option value="All">Tất cả trạng thái</option>
            <option value="Hoạt động">Hoạt động</option>
            <option value="Ngưng hoạt động">Ngưng hoạt động</option>
        </select>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary">Lọc</button>
    </div>
</form>

<table class="table table-bordered table-striped align-middle">
    <thead class="table-dark">
        <tr>
            <th>STT</th>
            <th>Tên giải trí</th>
            <th>Ảnh</th>
            <th>Loại giải trí</th>
            <th>Đánh giá (Thang 10)</th>
            <th>Trạng thái</th>
            <th>Open Time</th>
            <th>Close Time</th>
            <th>Ticket Price</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.EntertainmentList != null && Model.EntertainmentList.Any())
        {
            foreach (var item in Model.EntertainmentList)
            {
                <tr>
                    <td>@stt</td>
                    <td>@item.Name</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Image))
                        {
                            <img src="~/@item.Image" alt="@item.Name" width="100" height="70" style="object-fit:cover;" />
                        }
                        else
                        {
                            <span>Không có ảnh</span>
                        }
                    </td>
                    <td>@item.Type</td>
                    <td>@(item.AverageRating?.ToString("0.0"))</td>
                    <td>
                        @if (item.Status == "Hoạt động")
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                        else if (item.Status == "Ngưng hoạt động")
                        {
                            <span class="badge bg-secondary">Ngưng hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark">Chưa có</span>
                        }
                    </td>
                    <td>@(item.OpenTime?.ToString("HH:mm"))</td>
                    <td>@(item.CloseTime?.ToString("HH:mm"))</td>
                    <td>@(item.TicketPrice?.ToString("N0")) VNĐ</td>
                    <td>
                        <a asp-page="./Detail" asp-route-id="@item.EntertainmentId" class="btn btn-info btn-sm">
                            Chi tiết
                        </a>
                        <a asp-page="./Edit" asp-route-id="@item.EntertainmentId" class="btn btn-warning btn-sm">
                            Cập nhật
                        </a>
                    </td>
                </tr>
                stt++;
            }
        }
        else
        {
            <tr>
                <td colspan="10" class="text-center">Không có dữ liệu giải trí.</td>
            </tr>
        }
    </tbody>
</table>