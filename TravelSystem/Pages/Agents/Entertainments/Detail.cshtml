@page "{id:int}"
@model TravelSystem.Pages.Agents.Entertainments.DetailsModel
@{
    ViewData["Title"] = "Chi tiết dịch vụ giải trí";
    var item = Model.EntertainmentDetail;
}

<h2 class="mb-4">Chi tiết dịch vụ giải trí</h2>

<div class="row">
    <div class="col-md-5">
        <div class="border rounded p-3 text-center bg-light">
            @if (!string.IsNullOrEmpty(item.Image))
            {
                <img src="~/@item.Image"
                     alt="@item.Name"
                     style="max-width:100%; max-height:320px; object-fit:cover;" />
            }
            else
            {
                <img src="https://via.placeholder.com/450x300?text=No+Image"
                     alt="No Image"
                     style="max-width:100%; max-height:320px; object-fit:cover;" />
            }
        </div>
    </div>

    <div class="col-md-7">
        <table class="table table-bordered">
            <tbody>
                <tr>
                    <th style="width:35%;">Tên dịch vụ</th>
                    <td>@item.Name</td>
                </tr>
                <tr>
                    <th>Loại giải trí</th>
                    <td>@item.Type</td>
                </tr>
                <tr>
                    <th>Tỉnh / thành phố</th>
                    <td>@item.City</td>
                </tr>
                <tr>
                    <th>Số điện thoại</th>
                    <td>@item.Phone</td>
                </tr>
                <tr>
                    <th>Trạng thái</th>
                    <td>
                        @if (item.Status == "Hoạt động")
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                        else if (item.Status == "Ngưng hoạt động")
                        {
                            <span class="badge bg-secondary">Ngưng hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark">Chưa có</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th>Đánh giá</th>
                    <td>@(item.Rate?.ToString("0.0")) / 10</td>
                </tr>
                <tr>
                    <th>Giờ mở cửa</th>
                    <td>@(item.OpenTime?.ToString("HH:mm"))</td>
                </tr>
                <tr>
                    <th>Giờ đóng cửa</th>
                    <td>@(item.CloseTime?.ToString("HH:mm"))</td>
                </tr>
                <tr>
                    <th>Ngày mở cửa</th>
                    <td>@item.DayOfWeekOpen</td>
                </tr>
                <tr>
                    <th>Giá vé</th>
                    <td>@(item.TicketPrice?.ToString("N0")) VNĐ</td>
                </tr>
                <tr>
                    <th>Mô tả</th>
                    <td>@item.Description</td>
                </tr>
            </tbody>
        </table>

        <div class="d-flex gap-2">
            <a asp-page="./Index" class="btn btn-secondary">Trở lại</a>
            <a asp-page="./Edit" asp-route-id="@item.EntertainmentId" class="btn btn-warning">Cập nhật</a>
        </div>
    </div>
</div>