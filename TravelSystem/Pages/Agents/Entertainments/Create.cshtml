@page
@model TravelSystem.Pages.Agents.Entertainments.CreateModel

<div class="container-fluid p-4">
    <div class="mb-3">
        <h2>Thêm dịch vụ giải trí</h2>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <form method="post" enctype="multipart/form-data" onsubmit="return confirm('Bạn có chắc muốn thêm dịch vụ giải trí này không?');">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Service.ServiceName" class="form-label">Tên dịch vụ giải trí</label>
                <select asp-for="Service.ServiceName" asp-items="Model.EntertainmentNameOptions" class="form-select"></select>
                <span asp-validation-for="Service.ServiceName" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Entertainment.DayOfWeekOpen" class="form-label">Ngày hoạt động</label>
                <input asp-for="Entertainment.DayOfWeekOpen" class="form-control" placeholder="Ví dụ: Thứ 2 - Chủ nhật" />
                <span asp-validation-for="Entertainment.DayOfWeekOpen" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Service.Address" class="form-label">Địa chỉ</label>
                <input asp-for="Service.Address" class="form-control" />
                <span asp-validation-for="Service.Address" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Service.PhoneNumber" class="form-label">Số điện thoại</label>
                <input asp-for="Service.PhoneNumber" class="form-control" />
                <span asp-validation-for="Service.PhoneNumber" class="text-danger"></span>
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="Service.Description" class="form-label">Mô tả</label>
                <textarea asp-for="Service.Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Service.Description" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Ảnh dịch vụ</label>
                <input asp-for="UploadImage" type="file" class="form-control" accept="image/*" />
            </div>

            <div class="col-md-3 mb-3">
                <label asp-for="Entertainment.OpenTime" class="form-label">Giờ mở cửa</label>
                <input asp-for="Entertainment.OpenTime" type="time" class="form-control" />
                <span asp-validation-for="Entertainment.OpenTime" class="text-danger"></span>
            </div>

            <div class="col-md-3 mb-3">
                <label asp-for="Entertainment.CloseTime" class="form-label">Giờ đóng cửa</label>
                <input asp-for="Entertainment.CloseTime" type="time" class="form-control" />
                <span asp-validation-for="Entertainment.CloseTime" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Entertainment.TicketPrice" class="form-label">Giá vé</label>
                <input asp-for="Entertainment.TicketPrice" type="number" step="0.01" min="0" class="form-control" />
                <span asp-validation-for="Entertainment.TicketPrice" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-success">Thêm dịch vụ</button>
            <a asp-page="./Index" class="btn btn-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}