@page "{id:int}"
@model TravelSystem.Pages.Agents.Vouchers.DetailsModel
@{
    ViewData["Title"] = "Chi tiết thẻ khuyến mãi";
}

<h2 class="mb-4">Chi tiết thẻ khuyến mãi</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="mb-3">
    <a asp-page="/Agents/Vouchers/Index" class="btn btn-secondary">Quay lại</a>
</div>

<div class="card shadow-sm" style="max-width: 700px;">
    <div class="card-header text-center fw-bold">
        Chi tiết thẻ khuyến mãi
    </div>
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Mã thẻ:</div>
            <div class="col-sm-8">@Model.Voucher.VoucherCode</div>
        </div>

        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Tên thẻ:</div>
            <div class="col-sm-8">@Model.Voucher.VoucherName</div>
        </div>

        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Mô tả:</div>
            <div class="col-sm-8">@Model.Voucher.Description</div>
        </div>

        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Phần trăm khuyến mãi:</div>
            <div class="col-sm-8">@Model.Voucher.PercentDiscount</div>
        </div>

        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Giảm tối đa:</div>
            <div class="col-sm-8">@Model.Voucher.MaxDiscountAmount</div>
        </div>

        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Giá tối thiểu áp dụng:</div>
            <div class="col-sm-8">@Model.Voucher.MinAmountApply</div>
        </div>

        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Ngày bắt đầu:</div>
            <div class="col-sm-8">@Model.Voucher.StartDate</div>
        </div>

        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Ngày kết thúc:</div>
            <div class="col-sm-8">@Model.Voucher.EndDate</div>
        </div>

        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Số lượng:</div>
            <div class="col-sm-8">@Model.Voucher.Quantity</div>
        </div>

        <div class="row mb-2">
            <div class="col-sm-4 fw-bold">Trạng thái:</div>
            <div class="col-sm-8">
                @(Model.Voucher.Status == 1 ? "Hoạt động" : "Không hoạt động")
            </div>
        </div>
    </div>
</div>