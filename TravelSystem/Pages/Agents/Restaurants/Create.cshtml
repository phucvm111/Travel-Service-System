@page
@model TravelSystem.Pages.Agents.Restaurants.CreateModel

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Thêm nhà hàng</h2>
        <a asp-page="./Index" class="btn btn-secondary">Quay lại</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <form method="post" enctype="multipart/form-data" onsubmit="return confirm('Bạn có chắc muốn thêm nhà hàng này không?');">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Service.ServiceName" class="form-label">Tên nhà hàng</label>
                <input asp-for="Service.ServiceName" class="form-control" placeholder="Nhập tên nhà hàng" />
                <span asp-validation-for="Service.ServiceName" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Restaurant.RestaurantType" class="form-label">Loại nhà hàng</label>
                <input asp-for="Restaurant.RestaurantType" class="form-control" placeholder="Ví dụ: Buffet, Hải sản, Chay..." />
                <span asp-validation-for="Restaurant.RestaurantType" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Service.Address" class="form-label">Địa chỉ</label>
                <input asp-for="Service.Address" class="form-control" placeholder="Nhập địa chỉ" />
                <span asp-validation-for="Service.Address" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Service.PhoneNumber" class="form-label">Số điện thoại</label>
                <input asp-for="Service.PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                <span asp-validation-for="Service.PhoneNumber" class="text-danger"></span>
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="Service.Description" class="form-label">Mô tả</label>
                <textarea asp-for="Service.Description" class="form-control" rows="4" placeholder="Nhập mô tả nhà hàng"></textarea>
                <span asp-validation-for="Service.Description" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="UploadImage" class="form-label">Ảnh nhà hàng</label>
                <input asp-for="UploadImage" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="UploadImage" class="text-danger"></span>
            </div>

            <div class="col-md-3 mb-3">
                <label asp-for="Restaurant.OpenTime" class="form-label">Giờ mở cửa</label>
                <input asp-for="Restaurant.OpenTime" type="time" class="form-control" />
                <span asp-validation-for="Restaurant.OpenTime" class="text-danger"></span>
            </div>

            <div class="col-md-3 mb-3">
                <label asp-for="Restaurant.CloseTime" class="form-label">Giờ đóng cửa</label>
                <input asp-for="Restaurant.CloseTime" type="time" class="form-control" />
                <span asp-validation-for="Restaurant.CloseTime" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-success">Thêm nhà hàng</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}