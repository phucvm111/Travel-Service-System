@page "{id:int}"
@model TravelSystem.Pages.Agents.Restaurants.EditModel
@{
    ViewData["Title"] = "Cập nhật nhà hàng";
}

<div class="container-fluid p-4">
    <div style="max-width: 760px;">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Cập nhật nhà hàng</h2>
            <a asp-page="./Index" class="btn btn-secondary">Quay lại</a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card">
            <div class="card-body">
                <form method="post" enctype="multipart/form-data" id="formEdit">
                    @Html.AntiForgeryToken()

                    <input asp-for="RestaurantId" type="hidden" />
                    <input asp-for="ServiceId" type="hidden" />
                    <input asp-for="ExistingImage" type="hidden" />

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ImageFile" class="form-label">
                                Hình ảnh mới
                                <small class="text-muted">(để trống nếu không đổi)</small>
                            </label>
                            <input asp-for="ImageFile"
                                   type="file"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewImg(this)" />
                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TimeOpen" class="form-label"></label>
                            <input asp-for="TimeOpen" type="time" class="form-control" />
                            <span asp-validation-for="TimeOpen" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TimeClose" class="form-label"></label>
                            <input asp-for="TimeClose" type="time" class="form-control" />
                            <span asp-validation-for="TimeClose" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Ảnh hiện tại / xem trước</label>
                            <div>
                                @if (!string.IsNullOrWhiteSpace(Model.ExistingImage))
                                {
                                    <img id="imgPreview"
                                         src="@Model.ExistingImage"
                                         alt="Preview"
                                         class="rounded border"
                                         style="max-height: 140px; object-fit: cover;" />
                                }
                                else
                                {
                                    <img id="imgPreview"
                                         alt="Preview"
                                         class="rounded border d-none"
                                         style="max-height: 140px; object-fit: cover;" />
                                    <div id="noImageText" class="text-muted">Chưa có hình ảnh</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <a asp-page="./Index" class="btn btn-secondary">Hủy</a>
                        <button type="button" class="btn btn-success" onclick="confirmUpdate()">Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function previewImg(input) {
            const preview = document.getElementById('imgPreview');
            const noImageText = document.getElementById('noImageText');

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');

                    if (noImageText) {
                        noImageText.style.display = 'none';
                    }
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function confirmUpdate() {
            const form = document.getElementById('formEdit');

            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            Swal.fire({
                title: 'Bạn có chắc chắn muốn cập nhật nhà hàng này?',
                text: 'Thông tin hiện tại sẽ được thay đổi.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Cập nhật',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }
    </script>
}