@page "{id:int}"
@model TravelSystem.Pages.Agents.Restaurants.DetailModel
@{
    ViewData["Title"] = "Chi tiết nhà hàng";
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Chi tiết nhà hàng</h2>
        <div>
            <a asp-page="./Index" class="btn btn-secondary">Quay lại</a>
            <a asp-page="./Edit" asp-route-id="@Model.RestaurantId" class="btn btn-success">Sửa</a>
        </div>
    </div>

    <div class="card">
        @* Ảnh nhà hàng *@
        @if (!string.IsNullOrWhiteSpace(Model.Image))
        {
            <img src="@Model.Image"
                 alt="@Model.Name"
                 class="card-img-top"
                 style="max-height: 320px; object-fit: cover;" />
        }
        else
        {
            <div class="bg-light text-center text-muted py-5 border-bottom">
                Chưa có hình ảnh
            </div>
        }

        <div class="card-body">
            <table class="table table-bordered table-striped mb-0">
                <tr>
                    <th style="width: 220px;">Tên nhà hàng</th>
                    <td>@Model.Name</td>
                </tr>
                <tr>
                    <th>Trạng thái</th>
                    <td>
                        <span class="badge @Model.BadgeClass">@Model.StatusText</span>
                    </td>
                </tr>
                <tr>
                    <th>Địa chỉ</th>
                    <td>@(string.IsNullOrWhiteSpace(Model.Address) ? "—" : Model.Address)</td>
                </tr>
                <tr>
                    <th>Số điện thoại</th>
                    <td>@(string.IsNullOrWhiteSpace(Model.Phone) ? "—" : Model.Phone)</td>
                </tr>
                <tr>
                    <th>Giờ hoạt động</th>
                    <td>@Model.OperatingHours</td>
                </tr>
                <tr>
                    <th>Mô tả</th>
                    <td>@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</td>
                </tr>
            </table>
        </div>
    </div>
</div>