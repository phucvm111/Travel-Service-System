@page
@model TravelSystem.Pages.Agents.Restaurants.IndexModel

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Quản lý nhà hàng</h2>
        <a asp-page="./Create" class="btn btn-success">Thêm nhà hàng</a>
    </div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4">
            <input asp-for="SearchName" class="form-control" placeholder="Tìm theo tên nhà hàng..." />
        </div>

        <div class="col-md-3">
            <select asp-for="StatusFilter" class="form-select">
                <option value="">-- Lọc theo trạng thái --</option>
                <option value="1">Hoạt động</option>
                <option value="0">Ngừng hoạt động</option>
            </select>
        </div>

        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
            <a asp-page="./Index" class="btn btn-secondary">Xóa lọc</a>
        </div>
    </form>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <table class="table table-bordered table-striped align-middle">
        <thead class="table-light">
            <tr>
                <th>STT</th>
                <th>Tên nhà hàng</th>
                <th>Ảnh</th>
                <th>Loại nhà hàng</th>
                <th>Giờ mở cửa</th>
                <th>Giờ đóng cửa</th>
                <th>Trạng thái</th>
                <th style="width:260px;">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @{
                int stt = (Model.PageNumber - 1) * Model.PageSize;
            }

            @if (Model.Restaurants != null && Model.Restaurants.Any())
            {
                foreach (var item in Model.Restaurants)
                {
                    stt++;
                    <tr>
                        <td>@stt</td>
                        <td>@item.Service?.ServiceName</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Service?.Image))
                            {
                                <img src="@item.Service.Image"
                                     alt="Restaurant Image"
                                     width="100"
                                     height="70"
                                     style="object-fit:cover; border-radius:6px;" />
                            }
                            else
                            {
                                <span>Không có ảnh</span>
                            }
                        </td>
                        <td>@item.RestaurantType</td>
                        <td>@(item.OpenTime.HasValue? item.OpenTime.Value.ToString(@"HH\:mm") : "")</td>
                        <td>@(item.CloseTime.HasValue? item.CloseTime.Value.ToString(@"HH\:mm") : "")</td>
                        <td>
                            @if (item.Service?.Status == 1)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ngừng hoạt động</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-2">
                                <a asp-page="./Details" asp-route-id="@item.ServiceId" class="btn btn-info btn-sm text-white">
                                    Chi tiết
                                </a>
                                <a asp-page="./Edit" asp-route-id="@item.ServiceId" class="btn btn-warning btn-sm">
                                    Sửa
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.ServiceId" class="btn btn-danger btn-sm">
                                    Đổi trạng thái
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">Không có nhà hàng nào.</td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link"
                           asp-page="./Index"
                           asp-route-pageNumber="@i"
                           asp-route-searchName="@Model.SearchName"
                           asp-route-statusFilter="@Model.StatusFilter">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>