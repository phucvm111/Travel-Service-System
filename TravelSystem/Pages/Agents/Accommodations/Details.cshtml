@page "{id:int}"
@model TravelSystem.Pages.Agents.Accommodations.DetailsModel

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">Chi tiết khách sạn</h4>
        </div>
        <div class="card-body">
            @if (Model.Accommodation?.Service != null)
            {
                <div class="row">
                    <div class="col-md-4">
                        @if (!string.IsNullOrWhiteSpace(Model.Accommodation.Service.Image))
                        {
                            <img src="~/@Model.Accommodation.Service.Image"
                                 class="img-fluid rounded border"
                                 style="max-height:280px; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="border rounded p-4 text-center text-muted">Không có ảnh</div>
                        }
                    </div>

                    <div class="col-md-8">
                        <table class="table table-bordered">
                            <tr>
                                <th>Tên khách sạn</th>
                                <td>@Model.Accommodation.Service.ServiceName</td>
                            </tr>
                            <tr>
                                <th>Địa chỉ</th>
                                <td>@Model.Accommodation.Service.Address</td>
                            </tr>
                            <tr>
                                <th>Số điện thoại</th>
                                <td>@Model.Accommodation.Service.PhoneNumber</td>
                            </tr>
                            <tr>
                                <th>Check-in</th>
                                <td>@Model.Accommodation.CheckInTime?.ToString(@"HH\:mm")</td>
                            </tr>
                            <tr>
                                <th>Check-out</th>
                                <td>@Model.Accommodation.CheckOutTime?.ToString(@"HH\:mm")</td>
                            </tr>
                            <tr>
                                <th>Hạng sao</th>
                                <td>@Model.Accommodation.StarRating</td>
                            </tr>
                            <tr>
                                <th>Trạng thái</th>
                                <td>@(Model.Accommodation.Service.Status == 1 ? "Hoạt động" : "Ngừng hoạt động")</td>
                            </tr>
                            <tr>
                                <th>Mô tả</th>
                                <td>@Model.Accommodation.Service.Description</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <a asp-page="./Edit" asp-route-id="@Model.Accommodation.ServiceId" class="btn btn-warning">Sửa</a>
                    <a asp-page="./Delete" asp-route-id="@Model.Accommodation.ServiceId" class="btn btn-danger">Xóa</a>
                    <a href="javascript:history.back()" class="btn btn-secondary">Trở lại</a>
                </div>
            }
        </div>
    </div>
</div>