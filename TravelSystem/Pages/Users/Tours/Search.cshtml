@page
@using TravelSystem.Pages.Users.Tours
@model TravelSystem.Pages.Users.Tours.SearchModel
@{
    // Tạo returnUrl chứa toàn bộ trạng thái filter hiện tại
    // Khi user quay lại từ Details, Search sẽ restore đúng filter
    var queryParams = new List<string>();
    if (!string.IsNullOrEmpty(Model.Budget)) queryParams.Add($"Budget={Uri.EscapeDataString(Model.Budget)}");
    if (!string.IsNullOrEmpty(Model.Departure)) queryParams.Add($"Departure={Uri.EscapeDataString(Model.Departure)}");
    if (!string.IsNullOrEmpty(Model.Destination)) queryParams.Add($"Destination={Uri.EscapeDataString(Model.Destination)}");
    if (Model.DepartureDate.HasValue) queryParams.Add($"DepartureDate={Model.DepartureDate.Value:yyyy-MM-dd}");
    if (Model.PageNumber > 1) queryParams.Add($"PageNumber={Model.PageNumber}");

    var returnUrl = "/Users/Tours/Search" + (queryParams.Any() ? "?" + string.Join("&", queryParams) : "");
}

<div class="container mt-4 mb-5">

    <div class="row">

        <!-- FILTER -->
        <div class="col-md-3">

            <form method="get">

                <div class="d-flex justify-content-between mb-3">
                    <h4>Bộ lọc tìm kiếm</h4>
                    <button type="button"
                            class="btn btn-danger btn-sm"
                            onclick="window.location.href='/Users/Tours/Search'">
                        Xóa bộ lọc
                    </button>
                </div>

                <!-- Budget -->
                <div class="mb-3">
                    <label class="fw-bold">Ngân sách</label>
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="border rounded p-2 w-100 d-flex align-items-center gap-2">
                                <input type="radio" name="Budget" value="under5"
                                       @(Model.Budget == "under5" ? "checked" : "") />
                                <span>Dưới 5 triệu</span>
                            </label>
                        </div>
                        <div class="col-6">
                            <label class="border rounded p-2 w-100 d-flex align-items-center gap-2">
                                <input type="radio" name="Budget" value="5-10"
                                       @(Model.Budget == "5-10" ? "checked" : "") />
                                <span>5 - 10 triệu</span>
                            </label>
                        </div>
                        <div class="col-6">
                            <label class="border rounded p-2 w-100 d-flex align-items-center gap-2">
                                <input type="radio" name="Budget" value="10-20"
                                       @(Model.Budget == "10-20" ? "checked" : "") />
                                <span>10 - 20 triệu</span>
                            </label>
                        </div>
                        <div class="col-6">
                            <label class="border rounded p-2 w-100 d-flex align-items-center gap-2">
                                <input type="radio" name="Budget" value="over20"
                                       @(Model.Budget == "over20" ? "checked" : "") />
                                <span>Trên 20 triệu</span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Start place -->
                <div class="mb-3">
                    <label>Điểm khởi hành</label>
                    <select name="Departure" class="form-control">
                        <option value="">Tất cả</option>
                        @foreach (var place in Model.StartPlaces)
                        {
                            if (Model.Departure == place)
                            {
                                <option value="@place" selected>@place</option>
                            }
                            else
                            {
                                <option value="@place">@place</option>
                            }
                        }
                    </select>
                </div>

                <!-- Destination -->
                <div class="mb-3">
                    <label>Điểm đến</label>
                    <select name="Destination" class="form-control">
                        <option value="">Tất cả</option>
                        @foreach (var place in Model.EndPlaces)
                        {
                            if (!string.IsNullOrEmpty(Model.Destination) && place.Contains(Model.Destination))
                            {
                                <option value="@place" selected>@place</option>
                            }
                            else
                            {
                                <option value="@place">@place</option>
                            }
                        }
                    </select>
                </div>

                <!-- Date -->
                <div class="mb-3">
                    <label>Ngày đi</label>
                    <input type="date"
                           class="form-control"
                           name="DepartureDate"
                           value="@Model.DepartureDate?.ToString("yyyy-MM-dd")" />
                </div>

                <button class="btn btn-primary w-100">Áp dụng</button>

            </form>

        </div>

        <!-- TOUR LIST -->
        <div class="col-md-9">

            <h3>Có @Model.TotalTours tour</h3>

            @foreach (var tour in Model.Tours)
            {
                <div class="card mb-3">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <img src="~/@tour.Image" class="img-fluid rounded-start" />
                        </div>
                        <div class="col-md-8">
                            <div class="card-body">
                                <h5>@tour.TourName</h5>
                                <p>
                                    Khởi hành: @tour.StartDay <br />
                                    Thời gian: @tour.NumberOfDay ngày <br />
                                    Khởi hành từ: @tour.StartPlace <br />
                                    Điểm đến: @tour.EndPlace <br />
                                    Còn: @tour.Quantity chỗ
                                </p>
                                <h4 class="text-danger">@String.Format("{0:N0} đ", tour.AdultPrice)</h4>

                                @* Truyền returnUrl vào Details để nút quay lại hoạt động đúng *@
                                <a asp-page="/Users/Tours/Details"
                                   asp-route-id="@tour.TourId"
                                   asp-route-returnUrl="@returnUrl"
                                   class="btn btn-success">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- PAGINATION -->
            <div class="mt-3">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <span class="btn btn-primary">@i</span>
                    }
                    else
                    {
                        <a class="btn btn-outline-primary"
                           asp-page="./Search"
                           asp-route-PageNumber="@i"
                           asp-route-budget="@Model.Budget"
                           asp-route-departure="@Model.Departure"
                           asp-route-destination="@Model.Destination"
                           asp-route-departureDate="@Model.DepartureDate">
                            @i
                        </a>
                    }
                }
            </div>

        </div>

    </div>

</div>

<style>
    label:has(input[type="radio"]:checked) {
        border: 2px solid #0d6efd;
        background: #f0f7ff;
    }
</style>
