@page
@model TravelSystem.Pages.Users.Tours.BookingDetailModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết đơn hàng";
    var b = Model.BookingItem;
    var tour = b.TourDeparture?.Tour;
    var agent = tour?.TravelAgent;
}

<style>
    body {
        background-color: #f8f9fa;
    }

    .section-title {
        font-weight: 700;
        font-size: 20px;
        color: #333;
        margin-bottom: 20px;
        border-left: 5px solid #f50057;
        padding-left: 15px;
    }

    .detail-card {
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        margin-bottom: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .detail-item {
        margin-bottom: 12px;
        font-size: 1.05rem;
    }

    .detail-label {
        font-weight: 600;
        color: #666;
        width: 180px;
        display: inline-block;
    }

    .status-badge {
        padding: 8px 15px;
        border-radius: 20px;
        font-weight: 600;
    }
</style>

<div class="container" style="margin-top: 50px; margin-bottom: 100px;">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="./MyBookings" class="btn btn-light shadow-sm me-3">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h2 class="mb-0 fw-bold">Chi tiết đơn hàng #@b.BookCode</h2>
    </div>

    <div class="row">
        <div class="col-lg-7">
            <div class="detail-card">
                <div class="section-title">Thông tin chuyến đi</div>
                <div class="detail-item"><span class="detail-label">Tên tour:</span> <span class="text-dark fw-bold">@tour?.TourName</span></div>
                <div class="detail-item"><span class="detail-label">Địa điểm:</span> @tour?.StartPlace <i class="fas fa-long-arrow-alt-right mx-2 text-muted"></i> @tour?.EndPlace</div>
                <div class="detail-item"><span class="detail-label">Ngày khởi hành:</span> @b.TourDeparture?.StartDate?.ToString("dd/MM/yyyy")</div>
                <div class="detail-item"><span class="detail-label">Số lượng:</span> @b.NumberAdult người lớn, @b.NumberChildren trẻ em</div>
                <hr />
                <div class="detail-item">
                    <span class="detail-label">Tổng tiền:</span>
                    <span class="text-danger fw-bold fs-4">@b.TotalPrice?.ToString("N0") VNĐ</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Trạng thái đơn:</span>
                    @switch (b.Status)
                    {
                        case 1:
                            <span class="badge bg-success status-badge">Đã thanh toán</span>
                            break;
                        case 2:

                            <span class="badge bg-danger status-badge">Bị hủy bởi bạn</span>
                            break;
                        case 3:

                            <span class="badge bg-danger status-badge">Bị hủy bởi đại lý</span>
                            break;
                        case 4:

                            <span class="badge bg-secondary status-badge">Đã hoàn thành</span>
                            break;
                        case 5:

                            <span class="badge bg-warning text-dark status-badge">Đã yêu cầu hoàn tiền</span>
                            break;
                        case 6:

                            <span class="badge bg-info text-dark status-badge">Đã hoàn tiền</span>
                            break;
                        case 7:

                            <span class="badge bg-dark status-badge">Chờ thanh toán</span>
                            break;
                        default:

                            <span class="badge bg-light text-dark status-badge">Không xác định</span>
                            break;
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="detail-card">
                <div class="section-title">Đơn vị lữ hành</div>
                <div class="text-center mb-4">
                    <i class="fas fa-id-badge fa-4x text-muted mb-3"></i>
                    <h5 class="fw-bold">@agent?.TravelAgentName</h5>
                </div>
                <div class="detail-item"><i class="fas fa-envelope me-2 text-primary"></i> @agent?.TravelAgentEmail</div>
                <div class="detail-item"><i class="fas fa-phone-alt me-2 text-primary"></i> @agent?.HotLine</div>
                <div class="detail-item"><i class="fas fa-map-marker-alt me-2 text-primary"></i> @agent?.TravelAgentAddress</div>

                @if (b.Status == 1)
                {
                    <div class="alert alert-info mt-4 mb-0 small">
                        <i class="fas fa-info-circle me-1"></i> Vui lòng liên hệ đại lý nếu có thay đổi về thông tin cá nhân trước ngày khởi hành.
                    </div>
                }
            </div>
        </div>
    </div>
</div>