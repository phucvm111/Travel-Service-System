@page
@model TravelSystem.Pages.Users.BookTours.BookingDetailModel
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<style>
    body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background-color: #f8f9fa;
    }

    main {
        flex: 1;
    }

    .section-title {
        font-weight: 700;
        font-size: 20px;
        color: #333;
        margin-bottom: 20px;
        border-left: 5px solid #f50057;
        padding-left: 15px;
    }

    .detail-card {
        background: #fff;
        padding: 30px;
        border: none;
        border-radius: 12px;
        margin-bottom: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .detail-item {
        margin-bottom: 12px;
        display: flex;
        border-bottom: 1px dashed #eee;
        padding-bottom: 8px;
    }

    .detail-label {
        font-weight: 600;
        color: #555;
        width: 180px;
        flex-shrink: 0;
    }

    .detail-value {
        color: #333;
    }

    .badge-status {
        font-size: 0.9rem;
        padding: 8px 15px;
        border-radius: 50px;
    }
</style>

<main class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold">Chi tiết đơn hàng #@Model.Booking.BookCode</h3>
                <a href="javascript:history.back()" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>

            @if (Model.Booking != null)
            {
                <div class="detail-card">
                    <div class="section-title">Thông tin chuyến đi</div>

                    <div class="detail-item">
                        <span class="detail-label">Tên tour:</span>
                        <span class="detail-value fw-bold text-primary">@Model.Tour?.TourName</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Ngày khởi hành:</span>
                        <span class="detail-value">@Model.Tour?.StartDay?.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Lịch trình:</span>
                        <span class="detail-value">@Model.Tour?.NumberOfDay ngày @(Model.Tour?.NumberOfDay - 1) đêm</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Số lượng khách:</span>
                        <span class="detail-value">@Model.Booking.NumberAdult người lớn, @Model.Booking.NumberChildren trẻ em</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Điểm đón:</span>
                        <span class="detail-value">@Model.Tour?.StartPlace</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Tổng thanh toán:</span>
                        <span class="detail-value fw-bold text-danger fs-5">@((Model.Booking.TotalPrice ?? 0).ToString("N0")) VNĐ</span>
                    </div>
                    <div class="detail-item border-0">
                        <span class="detail-label">Trạng thái:</span>
                        <span class="badge @GetStatusClass(Model.Booking.Status) badge-status">
                            @GetStatusName(Model.Booking.Status)
                        </span>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="section-title">Thông tin người đặt</div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="detail-item border-0"><span class="detail-label">Họ và tên:</span> <span class="detail-value">@Model.Booking.FirstName @Model.Booking.LastName</span></div>
                            <div class="detail-item border-0"><span class="detail-label">Email liên hệ:</span> <span class="detail-value">@Model.Booking.Gmail</span></div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-item border-0"><span class="detail-label">Số điện thoại:</span> <span class="detail-value">@Model.Booking.Phone</span></div>
                            <div class="detail-item border-0"><span class="detail-label">Ghi chú:</span> <span class="detail-value italic text-muted">@(string.IsNullOrEmpty(Model.Booking.Note) ? "Không có" : Model.Booking.Note)</span></div>
                        </div>
                    </div>
                </div>

                @if (Model.TravelAgent != null)
                {
                    <div class="detail-card">
                        <div class="section-title">Đơn vị tổ chức</div>
                        <div class="detail-item"><span class="detail-label">Tên đại lý:</span> <span class="detail-value fw-bold">@Model.TravelAgent.TravelAgentName</span></div>
                        <div class="detail-item"><span class="detail-label">Địa chỉ:</span> <span class="detail-value">@Model.TravelAgent.TravelAgentAddress</span></div>
                        <div class="detail-item"><span class="detail-label">Hotline:</span> <span class="detail-value text-success fw-bold">@Model.TravelAgent.HotLine</span></div>
                        <div class="detail-item border-0"><span class="detail-label">Email hỗ trợ:</span> <span class="detail-value">@Model.TravelAgent.TravelAgentGmail</span></div>
                    </div>
                }
            }
        </div>
    </div>
</main>

@functions {
    string GetStatusClass(int? status) => status switch
    {
        1 => "bg-success",
        2 => "bg-danger",
        3 => "bg-danger",
        4 => "bg-primary",
        5 => "bg-warning text-dark",
        6 => "bg-info text-dark",
        7 => "bg-secondary",
        _ => "bg-dark"
    };

    string GetStatusName(int? status) => status switch
    {
        1 => "Đã thanh toán",
        2 => "Bị hủy bởi bạn",
        3 => "Đại lý hủy",
        4 => "Hoàn thành",
        5 => "Chờ hoàn tiền",
        6 => "Đã hoàn tiền",
        7 => "Chờ thanh toán",
        _ => "Không rõ"
    };
}