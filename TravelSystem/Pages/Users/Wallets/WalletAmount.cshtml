@page
@model TravelSystem.Pages.Users.Wallets.WalletAmountModel
@{
    ViewData["Title"] = "Ví của tôi";
    Layout = "_Layout";
}

<style>
    .balance-box {
        background-color: #fff3cd;
        border: 1px solid #ffeeba;
        padding: 20px;
        border-radius: 6px;
        margin-bottom: 30px;
    }

    .card-header h5 {
        font-weight: bold;
    }

    .table th, .table td {
        vertical-align: middle;
    }

    .pagination .page-item.active .page-link {
        background-color: #198754;
        border-color: #198754;
    }
</style>

<div class="container mt-5 mb-5">

    <div class="balance-box text-center shadow-sm">
        <h5 class="mb-2 text-dark">Số dư hiện tại:</h5>
        <h3 class="text-success fw-bold">
            @(Model.Wallet?.Balance?.ToString("N0") ?? "0") VNĐ
        </h3>
    </div>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert alert-danger">@Model.Error</div>
    }
    @if (Request.Query["success"] == "1")
    {
        <div id="successAlert" class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-check-circle me-3 fa-lg"></i>
                <div>
                    <strong>Gửi yêu cầu rút tiền thành công!</strong> @TempData["SuccessMessage"]
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>

        <script>
            // Tự động đóng alert sau 5 giây
            setTimeout(function() {
                var alertElement = document.getElementById('successAlert');
                if (alertElement) {
                    var bsAlert = new bootstrap.Alert(alertElement);
                    bsAlert.close();
                }
            }, 5000);
        </script>
    }

    <div class="card mb-5 shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Nạp tiền vào ví</h5>
        </div>

        <div class="card-body">
            <form method="post" id="rechargeForm">
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Nhập số tiền muốn nạp (Tối thiểu 10.000 VNĐ)
                    </label>
                    <input type="number"
                           class="form-control"
                           asp-for="Amount"
                           id="amount"
                           min="10000"
                           max="1000000000"
                           placeholder="Ví dụ: 50000"
                           required>
                    <div id="amountError" class="text-danger mt-1 small"></div>
                </div>

                <button type="submit"
                        class="btn btn-success"
                        id="submitBtn"
                        disabled>
                    Nạp tiền
                </button>

                @if (Model.User.RoleId == 2 || Model.User.RoleId == 3)
                {
                    <a href="withdrawotp" class="btn btn-danger">
                        <i class="fas fa-money-bill-wave me-1"></i> Rút tiền
                    </a>
                }
            </form>
        </div>
    </div>

    <div class="py-3">
        <form method="get" class="row g-3 align-items-center">
            <div class="col-auto">
                <label class="col-form-label fw-semibold">Lọc theo loại</label>
            </div>
            <div class="col-auto">
                <select class="form-select" name="type">
                    <option value="">Tất cả</option>
                    <option value="RECHARGE">Nạp</option>
                    <option value="PURCHASE">Thanh toán chuyến đi</option>
                    <option value="REFUND">Hoàn</option>
                    <option value="WITHDRAW">Rút tiền</option>
                    <option value="RECEIVE">Nhận tiền chuyến đi</option>
                </select>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary" type="submit">Lọc</button>
            </div>
        </form>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Lịch sử giao dịch</h5>
        </div>

        <div class="card-body p-0">
            @if (Model.TransactionHistoryList == null || !Model.TransactionHistoryList.Any())
            {
                <div class="p-4 text-center text-muted">Không có giao dịch nào.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ngày giao dịch</th>
                                <th>Mô tả</th>
                                <th>Loại</th>
                                <th>Số tiền</th>
                                <th>Số dư cuối</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.TransactionHistoryList)
                            {
                                <tr>
                                    <td>@t.TransactionDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@t.Description</td>
                                    <td>
                                        <span class="badge @(t.TransactionType == "RECHARGE" ? "bg-success" : "bg-secondary")">
                                            @t.TransactionType
                                        </span>
                                    </td>
                                    <td class="fw-bold">@t.Amount.ToString("N0") VNĐ</td>
                                    <td>@t.AmountAfterTransaction?.ToString("N0") VNĐ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4 mb-5">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const amountInput = document.getElementById("amount");
        const errorDiv = document.getElementById("amountError");
        const submitBtn = document.getElementById("submitBtn");

        function validateAmount() {
            const value = parseInt(amountInput.value);
            if (isNaN(value)) {
                submitBtn.disabled = true;
                errorDiv.textContent = "";
                return;
            }

            if (value < 10000) {
                errorDiv.textContent = "Số tiền nạp tối thiểu là 10.000 VNĐ";
                submitBtn.disabled = true;
            } else if (value > 1000000000) {
                errorDiv.textContent = "Số tiền vượt quá hạn mức cho phép";
                submitBtn.disabled = true;
            } else {
                errorDiv.textContent = "";
                submitBtn.disabled = false;
            }
        }
        amountInput.addEventListener("input", validateAmount);
    });
</script>