@page
@model TravelSystem.Pages.Users.Wallets.WithdrawOtpModel
@{
    ViewData["Title"] = "Xác thực OTP";
    Layout = "_Layout";
}

<style>
    body {
        background-color: #f4f6f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .otp-card {
        max-width: 500px;
        margin: 60px auto;
        padding: 30px;
        border-radius: 15px;
        background: #ffffff;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .otp-input {
        width: 50px;
        height: 55px;
        font-size: 24px;
        text-align: center;
        border: 1px solid #ced4da;
        border-radius: 8px;
    }

    .otp-container {
        display: flex;
        justify-content: space-between;
        gap: 10px;
    }

    .timer {
        font-weight: bold;
        color: #dc3545;
        font-size: 16px;
    }

    .resend-link {
        font-size: 14px;
    }

    .fade-in {
        animation: fadeIn 0.3s ease-in;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

<div class="otp-card">
    <h4 class="text-center text-success fw-bold mb-3">Xác thực mã OTP</h4>
    <p class="text-center">Mã gồm 6 chữ số đã được gửi đến email của bạn.</p>

    <div class="text-center timer mb-3">
        Mã OTP sẽ hết hạn sau: <span id="countdown">--:--</span>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger text-center fade-in">
            <i class="fas fa-exclamation-circle me-1"></i> @Model.ErrorMessage
            @if (Model.RemainingTries.HasValue)
            {
                <br />
        
                <span>Bạn còn <strong>@Model.RemainingTries</strong> lần thử.</span>
            }
        </div>
    }

    <form method="post" class="text-center">
        <div class="otp-container justify-content-center mb-3">
            <input type="text" maxlength="1" class="form-control otp-input" name="Digits" required autocomplete="off">
            <input type="text" maxlength="1" class="form-control otp-input" name="Digits" required autocomplete="off">
            <input type="text" maxlength="1" class="form-control otp-input" name="Digits" required autocomplete="off">
            <input type="text" maxlength="1" class="form-control otp-input" name="Digits" required autocomplete="off">
            <input type="text" maxlength="1" class="form-control otp-input" name="Digits" required autocomplete="off">
            <input type="text" maxlength="1" class="form-control otp-input" name="Digits" required autocomplete="off">
        </div>

        <button type="submit" class="btn btn-success px-4 w-100">
            <i class="fas fa-check-circle me-1"></i> Xác nhận
        </button>
    </form>

    <p class="text-center mt-3 resend-link">
        Không nhận được mã? <a asp-page-handler="Resend" class="text-primary">Gửi lại</a>
    </p>
</div>

@section Scripts {
    <script>
        const inputs = document.querySelectorAll('.otp-input');
        inputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                if (e.target.value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && e.target.value.length === 0 && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        const expiryTime = @Model.OtpExpiry;
        const countdownEl = document.getElementById("countdown");

        const timer = setInterval(() => {
            const now = new Date().getTime();
            const distance = expiryTime - now;

            if (distance <= 0) {
                clearInterval(timer);
                countdownEl.textContent = "Đã hết hạn";

                setTimeout(() => {
                    alert("Mã OTP đã hết hạn. Vui lòng yêu cầu mã mới.");
                    window.location.href = "/Users/Wallets/WalletAmount";
                }, 1000);
            } else {
                const minutes = Math.floor(distance / 1000 / 60).toString().padStart(2, '0');
                const seconds = Math.floor((distance / 1000) % 60).toString().padStart(2, '0');
                countdownEl.textContent = minutes + ":" + seconds;
            }
        }, 1000);
    </script>
}