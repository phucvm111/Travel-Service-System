@page
@model TravelSystem.Pages.Users.Wallets.WithdrawFormModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Thông tin rút tiền";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    .container1 {
        max-width: 1140px;
        background: #fff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 0 12px rgba(0,0,0,0.1);
        margin: 40px auto 80px;
    }

    .agreement-check {
        margin-top: 30px;
        font-weight: 500;
    }

    .btn-submit {
        padding: 10px 40px;
        font-weight: 600;
        font-size: 16px;
    }

    .section-title {
        font-weight: 700;
        color: #333;
    }
</style>

<div class="container1 py-4">
    <div class="mb-3">
        <a asp-page="./AmountToPay" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="p-4 border rounded shadow-sm bg-light">
                <h5 class="text-success fw-bold mb-3">📌 Điều khoản rút tiền cho khách hàng</h5>
                <ol class="small lh-base" style="line-height: 1.8;">
                    <li><strong>Chính sách:</strong> Cung cấp thông tin chính xác.</li>
                    <li><strong>Thời gian:</strong> 1–3 ngày làm việc.</li>
                    <li><strong>Phí:</strong> Tùy thuộc ngân hàng.</li>
                    <li><strong>Giới hạn:</strong> Tối đa 100 triệu/lần.</li>
                    <li><strong>Bảo mật:</strong> Cam kết an toàn dữ liệu.</li>
                </ol>
                <div class="mt-4 p-3 bg-white rounded border border-success">
                    <p class="mb-0 text-muted small">Số dư hiện tại</p>
                    <h3 class="fw-bold text-primary mb-0">@Model.UserBalance.ToString("N0") VNĐ</h3>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Mess))
            {
                <div class="alert alert-danger mt-3 small">@Model.Mess</div>
            }
        </div>

        <div class="col-md-7">
            <form method="post">
                <input type="hidden" id="currentBalance" value="@Model.UserBalance" />
                <h4 class="text-center mb-4 section-title">Nhập thông tin rút tiền</h4>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-bold">Ngân hàng nhận tiền: <span class="text-danger">*</span></label>
                        <select id="bankSelect" asp-for="BankName" class="form-select" required>
                            <option value="">-- Chọn ngân hàng --</option>
                            <option value="VCB">Vietcombank - Ngân hàng TMCP Ngoại thương Việt Nam</option>
                            <option value="CTG">VietinBank - Ngân hàng TMCP Công thương Việt Nam</option>
                            <option value="BIDV">BIDV - Ngân hàng TMCP Đầu tư và Phát triển Việt Nam</option>
                            <option value="TCB">Techcombank - Ngân hàng TMCP Kỹ Thương Việt Nam</option>
                            <option value="MB">MB Bank - Ngân hàng TMCP Quân đội</option>
                            <option value="VBA">Agribank - Ngân hàng Nông nghiệp và Phát triển Nông thôn VN</option>
                            <option value="STB">Sacombank - Ngân hàng TMCP Sài Gòn Thương Tín</option>
                            <option value="ACB">ACB - Ngân hàng TMCP Á Châu</option>
                            <option value="HDB">HDBank - Ngân hàng TMCP Phát triển TP.HCM</option>
                            <option value="VPB">VPBank - Ngân hàng TMCP Việt Nam Thịnh Vượng</option>
                            <option value="EIB">Eximbank - Ngân hàng TMCP Xuất Nhập Khẩu Việt Nam</option>
                            <option value="SCB">SCB - Ngân hàng TMCP Sài Gòn</option>
                            <option value="VIB">VIB - Ngân hàng TMCP Quốc tế Việt Nam</option>
                            <option value="OCB">OCB - Ngân hàng TMCP Phương Đông</option>
                            <option value="SHB">SHB - Ngân hàng TMCP Sài Gòn Hà Nội</option>
                            <option value="TPB">TPBank - Ngân hàng TMCP Tiên Phong</option>
                            <option value="MSB">MSB - Ngân hàng TMCP Hàng Hải Việt Nam</option>
                            <option value="PGB">PG Bank - Ngân hàng TMCP Xăng dầu Petrolimex</option>
                            <option value="BAB">Bắc Á Bank - Ngân hàng TMCP Bắc Á</option>
                            <option value="LPB">LienVietPostBank - Ngân hàng TMCP Bưu điện Liên Việt</option>
                            <option value="NAB">Nam Á Bank - Ngân hàng TMCP Nam Á</option>
                            <option value="KLB">KienLongBank - Ngân hàng TMCP Kiên Long</option>
                            <option value="VAB">VietABank - Ngân hàng TMCP Việt Á</option>
                            <option value="SGCB">Saigonbank - Ngân hàng TMCP Sài Gòn Công Thương</option>
                            <option value="ABB">ABBANK - Ngân hàng TMCP An Bình</option>
                            <option value="SGB">Saigonbank - Ngân hàng TMCP Sài Gòn Công Thương</option>
                            <option value="SEAB">SeABank - Ngân hàng TMCP Đông Nam Á</option>
                            <option value="BVB">Baoviet Bank - Ngân hàng TMCP Bảo Việt</option>
                            <option value="COB">CBBank - Ngân hàng Xây Dựng</option>
                            @* Thêm các ngân hàng khác ở đây *@
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Số tài khoản: <span class="text-danger">*</span></label>
                        <input asp-for="AccountNumber" class="form-control" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên tài khoản: <span class="text-danger">*</span></label>
                        <input asp-for="AccountName" class="form-control" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Số điện thoại: <span class="text-danger">*</span></label>
                        <input asp-for="Phone" type="tel" class="form-control" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Số tiền rút: <span class="text-danger">*</span></label>
                        <input asp-for="Amount" id="amountInput" type="number" class="form-control" required min="10000" />
                        <div id="amountErrorClient" class="text-danger small" style="display:none;"></div>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-bold">Số CCCD: <span class="text-danger">*</span></label>
                        <input asp-for="Cccd" class="form-control" readonly />
                    </div>
                </div>

                <h4 class="text-center mt-5 mb-4 section-title">Tài liệu xác thực</h4>
                <div class="row g-4 text-center">
                    <div class="col-md-6">
                        <label class="small fw-bold">Mặt trước CCCD</label>
                        <img id="prevFront" src="/@Model.TouristInfo?.IdCardFrontImage" class="img-thumbnail d-block mb-2" style="height:150px; width:100%; object-fit:cover" />
                    </div>
                    <div class="col-md-6">
                        <label class="small fw-bold">Mặt sau CCCD</label>
                        <img id="prevBack" src="/@Model.TouristInfo?.IdCardBackImage" class="img-thumbnail d-block mb-2" style="height:150px; width:100%; object-fit:cover" />
                    </div>
                </div>

                <div class="form-check agreement-check">
                    <input class="form-check-input" type="checkbox" id="agreeCheckbox">
                    <label class="form-check-label" for="agreeCheckbox">
                        Tôi cam kết đã điền đúng thông tin và đồng ý với điều khoản rút tiền.
                    </label>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" id="submitBtn" class="btn btn-success btn-submit" disabled>
                        <i class="fas fa-paper-plane me-2"></i> Gửi yêu cầu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#bankSelect').select2({ placeholder: "Chọn ngân hàng" });

            const $amountInput = $('#amountInput');
            const $submitBtn = $('#submitBtn');
            const $agreeCheck = $('#agreeCheckbox');
            const balance = parseFloat($('#currentBalance').val());

            function validate() {
                const val = parseFloat($amountInput.val());
                const isAmountValid = !isNaN(val) && val >= 10000 && val <= balance;

                if (val > balance) {
                    $('#amountErrorClient').text("Vượt quá số dư!").show();
                } else {
                    $('#amountErrorClient').hide();
                }

                $submitBtn.prop('disabled', !($agreeCheck.is(':checked') && isAmountValid));
            }

            $amountInput.on('input', validate);
            $agreeCheck.on('change', validate);
        });
    </script>
}