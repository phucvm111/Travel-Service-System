@page
@model TravelSystem.Pages.Users.Wallets.WithdrawFormModel
@{
    ViewData["Title"] = "Thông tin rút tiền";
    Layout = "_Layout";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<style>
    body {
        background: #f8f9fa;
        font-family: 'Segoe UI', sans-serif;
    }
    .container-withdraw {
        max-width: 1140px;
        background: #fff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 0 12px rgba(0,0,0,0.1);
        margin-top: 40px;
        margin-bottom: 80px;
    }
    .agreement-check {
        margin-top: 30px;
        font-weight: 500;
    }
    .btn-submit {
        padding: 10px 40px;
        font-weight: 600;
        font-size: 16px;
    }
    .section-title {
        font-weight: 700;
        color: #333;
    }
    .img-preview {
        max-height: 200px;
        border: 2px dashed #ddd;
        padding: 5px;
    }
</style>

<div class="container-withdraw py-4 mx-auto">
    <div class="mb-3">
        <a asp-page="/Users/Wallets/WalletAmount" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>

    <div class="row">    
        <div class="col-md-5 mb-4">
            <div class="p-3 border rounded shadow-sm bg-light">
                <h5 class="text-success fw-bold mb-3">📌 Điều khoản rút tiền cho khách hàng.</h5>
                <ol class="small lh-base" style="line-height: 1.8;">
                    <li><strong>Chính sách:</strong> Cung cấp thông tin ngân hàng, CCCD rõ ràng và chính xác.</li>
                    <li><strong>Thời gian xử lý:</strong> 1–3 ngày làm việc (trừ cuối tuần và lễ).</li>
                    <li><strong>Phí:</strong> Có thể áp dụng tùy ngân hàng.</li>
                    <li><strong>Giới hạn:</strong> Tối đa 100 triệu/lần.</li>
                    <li><strong>Lý do từ chối:</strong> Sai thông tin, hình ảnh không hợp lệ, nghi ngờ gian lận.</li>
                    <li><strong>Bảo mật:</strong> Cam kết không chia sẻ dữ liệu.</li>
                    <li><strong>Hỗ trợ:</strong> Gọi 1900 123 456 hoặc email goviet1901@gmail.com</li>
                </ol>
                <p class="mt-3 fw-bold text-primary">
                    💰 Số dư hiện tại của bạn: @Model.Balance.ToString("N0") VNĐ
                </p>
            </div>
            
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger mt-3 small">@Model.ErrorMessage</div>
            }
        </div>

        <div class="col-md-7">
            <form method="post" enctype="multipart/form-data">
                <input type="hidden" id="currentBalance" value="@Model.Balance" />
                
                <h4 class="text-center mb-4 section-title">Nhập thông tin rút tiền</h4>
                
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label">Ngân hàng nhận tiền: <span class="text-danger">*</span></label>
                        <select id="bankSelect" asp-for="BankName" class="form-select" required>
                            <option value="">-- Chọn ngân hàng --</option>
                            <option value="VCB">Vietcombank - Ngân hàng TMCP Ngoại thương Việt Nam</option>
                            <option value="CTG">VietinBank - Ngân hàng TMCP Công thương Việt Nam</option>
                            <option value="BIDV">BIDV - Ngân hàng TMCP Đầu tư và Phát triển Việt Nam</option>
                            <option value="TCB">Techcombank - Ngân hàng TMCP Kỹ Thương Việt Nam</option>
                            <option value="MB">MB Bank - Ngân hàng TMCP Quân đội</option>
                            <option value="VBA">Agribank - Ngân hàng Nông nghiệp và Phát triển Nông thôn VN</option>
                            <option value="STB">Sacombank - Ngân hàng TMCP Sài Gòn Thương Tín</option>
                            <option value="ACB">ACB - Ngân hàng TMCP Á Châu</option>
                            <option value="VPB">VPBank - Ngân hàng TMCP Việt Nam Thịnh Vượng</option>
                            <option value="TPB">TPBank - Ngân hàng TMCP Tiên Phong</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Số tài khoản: <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" asp-for="AccountNumber" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Tên tài khoản nhận tiền: <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" asp-for="AccountName" placeholder="Ví dụ: NGUYEN VAN A" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại: <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control" asp-for="Phone" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Số tiền: <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" asp-for="Amount" id="amountInput" required>
                        <div class="text-danger small" id="amountErrorClient" style="display:none;"></div>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Số CCCD (12 số): <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" asp-for="Cccd" required>
                    </div>
                </div>

                <h4 class="text-center mt-5 mb-4 section-title">Tài liệu xác thực</h4>
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label">CCCD mặt trước: <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" asp-for="CccdFront" accept="image/*" required onchange="previewImage(this, 'previewFront')">
                        <img id="previewFront" class="img-fluid mt-2 rounded img-preview" src="#" alt="Preview" hidden>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">CCCD mặt sau: <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" asp-for="CccdBack" accept="image/*" required onchange="previewImage(this, 'previewBack')">
                        <img id="previewBack" class="img-fluid mt-2 rounded img-preview" src="#" alt="Preview" hidden>
                    </div>
                </div>

                <div class="form-check agreement-check text-start mt-4">
                    <input class="form-check-input" type="checkbox" id="agreeCheckbox">
                    <label class="form-check-label" for="agreeCheckbox">
                        Tôi cam kết đã điền đúng thông tin và đồng ý với điều khoản rút tiền.
                    </label>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-success btn-submit" id="submitBtn" disabled>
                        <i class="fas fa-paper-plane me-2"></i> Gửi yêu cầu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        function previewImage(input, imgId) {
            const file = input.files[0];
            const preview = document.getElementById(imgId);
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.hidden = false;
                };
                reader.readAsDataURL(file);
            }
        }

        $(document).ready(function () {
            $('#bankSelect').select2({
                placeholder: "Chọn hoặc nhập tên ngân hàng",
                allowClear: true
            });

            const amountInput = document.getElementById('amountInput');
            const submitBtn = document.getElementById('submitBtn');
            const amountErrorClient = document.getElementById('amountErrorClient');
            const agreeCheckbox = document.getElementById('agreeCheckbox');
            const balance = parseFloat(document.getElementById("currentBalance").value);

            function validateForm() {
                const enteredAmount = parseFloat(amountInput.value);
                let isAmountValid = true;

                if (!isNaN(enteredAmount)) {
                    if (enteredAmount > balance) {
                        amountErrorClient.textContent = "Số tiền rút vượt quá số dư hiện có!";
                        amountErrorClient.style.display = "block";
                        isAmountValid = false;
                    } else if (enteredAmount < 10000) {
                        amountErrorClient.textContent = "Số tiền rút tối thiểu là 10,000 VNĐ";
                        amountErrorClient.style.display = "block";
                        isAmountValid = false;
                    } else {
                        amountErrorClient.style.display = "none";
                    }
                } else {
                    isAmountValid = false;
                }

                submitBtn.disabled = !(agreeCheckbox.checked && isAmountValid);
            }

            amountInput.addEventListener("input", validateForm);
            agreeCheckbox.addEventListener("change", validateForm);
        });
    </script>
}