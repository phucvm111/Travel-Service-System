@page
@model TravelSystem.Pages.Wallet.AmountToPayModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Ví của tôi";
}

<div class="container py-4">
    @* --- Khối Số Dư --- *@
    <div class="balance-box text-center shadow-sm p-4 mb-4 bg-white border rounded">
        <h5 class="text-muted mb-2">Số dư khả dụng</h5>
        <h2 class="text-primary fw-bold">@Model.CurrentUser.Balance?.ToString("N0") <small>VNĐ</small></h2>

        <div class="mt-3 d-flex justify-content-center gap-2">
            @* NÚT RÚT TIỀN: Chuyển sang trang Withdraw *@
            <a asp-page="/Users/Wallets/WithdrawOTP" asp-route-id="@HttpContext.Session.GetInt32("UserID")" class="btn btn-outline-danger px-4 shadow-sm">
                <i class="fas fa-university me-2"></i>Rút tiền về ngân hàng
            </a>
        </div>
    </div>

    @* --- Form Nạp Tiền --- *@
    <div class="card shadow-sm mb-5 border-0">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-wallet me-2"></i>Nạp tiền vào ví qua PayOS</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Deposit" id="depositForm">
                <div class="row align-items-end">
                    <div class="col-md-8">
                        <label class="form-label fw-bold">Số tiền nạp (VNĐ)</label>
                        <input type="number" name="amount" id="amountInput" class="form-control form-control-lg" placeholder="Nhập số tiền (ít nhất 10.000VNĐ)..." min="10000" required />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" id="btnSubmit" class="btn btn-success btn-lg w-100" disabled>
                            Nạp tiền ngay
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* --- Lịch Sử Giao Dịch --- *@
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Lịch sử giao dịch</h5>
            <form method="get" class="m-0">
                <select name="type" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Tất cả giao dịch</option>
                    <option value="DEPOSIT" selected="@(Model.SelectedType == "RECHARGE")">Nạp tiền</option>
                    <option value="PURCHASE" selected="@(Model.SelectedType == "PURCHASE")">Thanh toán</option>
                    <option value="REFUND" selected="@(Model.SelectedType == "REFUND")">Hoàn tiền</option>
                    <option value="WITHDRAW" selected="@(Model.SelectedType == "WITHDRAW")">Rút tiền</option>
                </select>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Thời gian</th>
                        <th>Nội dung</th>
                        <th class="text-center">Loại</th>
                        <th class="text-end pe-3">Biến động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Transactions != null && Model.Transactions.Any())
                    {
                        foreach (var item in Model.Transactions)
                        {
                            <tr>
                                <td class="ps-3 text-muted">@item.TransactionDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.Description</td>
                                <td class="text-center">
                                    @{
                                        // Thêm trường hợp "RECEIVE" vào logic màu xanh
                                        var badgeClass = item.TransactionType switch
                                        {
                                            "RECHARGE" or "RECEIVE" => "bg-success", // Cả nạp tiền và nhận tiền đều màu xanh
                                            "PURCHASE" => "bg-danger",
                                            "REFUND" => "bg-warning text-dark",
                                            "WITHDRAW" => "bg-info text-white",
                                            _ => "bg-secondary"
                                        };
                                        var typeLabel = item.TransactionType switch
                                        {
                                            "RECHARGE" => "Nạp tiền",
                                            "RECEIVE" => "Hoàn tiền", // Đổi label RECEIVE thành Hoàn tiền cho thân thiện
                                            "PURCHASE" => "Thanh toán",
                                            "REFUND" => "Hoàn tiền",
                                            "WITHDRAW" => "Rút tiền",
                                            _ => item.TransactionType
                                        };
                                    }
                                    <span class="badge @badgeClass" style="width: 85px;">@typeLabel</span>
                                </td>

                                @* --- PHẦN HIỂN THỊ BIẾN ĐỘNG TIỀN (+/-) --- *@
                                <td class="text-end fw-bold pe-3">
                                    @* Sửa điều kiện: RECHARGE hoặc RECEIVE (Hoàn tiền) đều là + tiền *@
                                    @if (item.TransactionType == "RECHARGE" || item.TransactionType == "RECEIVE" || item.TransactionType == "REFUND")
                                    {
                                        <span class="text-success">+ @item.Amount?.ToString("N0") VNĐ</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">- @item.Amount?.ToString("N0") VNĐ</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center py-5 text-muted">Chưa có giao dịch nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Dùng Html.Raw để giữ nguyên tiếng Việt không bị mã hóa Unicode
        var successMsg = '@Html.Raw(TempData["SuccessMessage"])';

        if (successMsg && successMsg !== '') {
            Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: successMsg,
                confirmButtonColor: '#28a745',
                confirmButtonText: 'Đồng ý'
            });
        }

        // Logic cũ của Hùng
        const input = document.getElementById('amountInput');
        const btn = document.getElementById('btnSubmit');
        if(input && btn) {
            input.addEventListener('input', () => {
                btn.disabled = input.value < 10000;
            });
        }
    </script>
}