@page
@using TravelSystem.Models
@model TravelSystem.Pages.Users.Profiles.DetailsModel

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    body {
        background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/img_10.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .profile-container {
        max-width: 900px;
        margin: 60px auto;
        background: #ffffff;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }

    .profile-header {
        border-bottom: 2px solid #f0f2f5;
        margin-bottom: 30px;
        padding-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
    }

    .profile-title {
        font-size: 28px;
        font-weight: 700;
        color: #0d6efd;
        margin: 0;
    }

    .section-title {
        font-size: 20px;
        font-weight: 600;
        color: #198754;
        margin: 30px 0 20px 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .profile-info {
        padding: 12px 15px;
        background: #f8f9fa;
        border-radius: 10px;
        border-left: 4px solid #0d6efd;
        transition: 0.3s;
    }

    .profile-info:hover {
        background: #eef2f7;
        transform: translateX(5px);
    }

    .profile-info label {
        font-weight: 700;
        color: #495057;
        width: 130px;
        display: inline-block;
        font-size: 0.9rem;
        text-transform: uppercase;
    }

    .tourist-card {
        background: #f0fdf4;
        border-left-color: #198754;
    }

    .id-card-img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px dashed #ccc;
        margin-top: 10px;
        transition: 0.3s;
    }

    .id-card-img:hover {
        border-color: #198754;
        cursor: pointer;
    }

    .btn-group-center {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-top: 40px;
    }

    .btn-custom {
        padding: 12px 35px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
    }

    .btn-edit { background: #28a745; color: white; }
    .btn-edit:hover { background: #218838; box-shadow: 0 4px 12px rgba(40,167,69,0.3); color: white; }

    .btn-back { background: #6c757d; color: white; }
    .btn-back:hover { background: #5a6268; box-shadow: 0 4px 12px rgba(108,117,125,0.3); color: white; }

    hr { opacity: 0.1; margin: 40px 0; }
</style>

<div class="profile-container">
    <div class="profile-header">
        <i class="fa-solid fa-user-circle fa-2x text-primary"></i>
        <h2 class="profile-title">Thông tin tài khoản</h2>
    </div>

    <div class="info-grid">
        <div class="profile-info">
            <label>Họ:</label> <span>@Model.User.LastName</span>
        </div>
        <div class="profile-info">
            <label>Tên:</label> <span>@Model.User.FirstName</span>
        </div>
        <div class="profile-info">
            <label>Email:</label> <span>@Model.User.Gmail</span>
        </div>
        <div class="profile-info">
                <label><i class="fa-solid fa-lock me-2"></i>Mật khẩu:</label>
                <span>******** <i class="fa-solid fa-eye-slash ms-2 text-muted" style="cursor:pointer"></i></span>
        </div>
        <div class="profile-info">
            <label>Số ĐT:</label> <span>@Model.User.Phone</span>
        </div>
        <div class="profile-info">
            <label>Giới tính:</label> <span>@Model.User.Gender</span>
        </div>
        <div class="profile-info">
            <label>Ngày sinh:</label> <span>@Model.User.Dob?.ToString("dd/MM/yyyy")</span>
        </div>
        <div class="profile-info">
        <label>Địa chỉ:</label> <span>@Model.User.Address</span>
    </div>
    </div>    
    <br />
    @if (Model.User.RoleId == 5 && Model.User.Tourist != null)
    {
            Tourist tourist = Model.User.Tourist;
            <div class="info-grid mb-4">
                <div class="profile-info tourist-card">
                    <label>Chủ TK:</label> <span>@tourist.AccountHolderName</span>
                </div>
                <div class="profile-info tourist-card">
                    <label>Số CCCD:</label> <span>@tourist.IdCard</span>
                </div>
                <div class="profile-info tourist-card">
                    <label>Ngân hàng:</label> <span>@tourist.BankName</span>
                </div>
                <div class="profile-info tourist-card">
                    <label>Số TK:</label> <span>@tourist.BankNumber</span>
                </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-md-6">
                    <div class="card border-0 bg-light p-2 text-center">
                        <small class="text-muted d-block mb-2 fw-bold">MẶT TRƯỚC CCCD</small>
                        @if (!string.IsNullOrEmpty(tourist.IdCardFrontImage))
                        {
                            <img src="~/@tourist.IdCardFrontImage" class="id-card-img" alt="Mặt trước" />
                        }
                        else
                        {
                            <div class="id-card-img d-flex align-items-center justify-content-center bg-white text-muted">Trống</div>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 bg-light p-2 text-center">
                        <small class="text-muted d-block mb-2 fw-bold">MẶT SAU CCCD</small>
                        @if (!string.IsNullOrEmpty(tourist.IdCardBackImage))
                        {
                            <img src="~/@tourist.IdCardBackImage" class="id-card-img" alt="Mặt sau" />
                        }
                        else
                        {
                            <div class="id-card-img d-flex align-items-center justify-content-center bg-white text-muted">Trống</div>
                        }
                    </div>
                </div>
            </div>
    }

    @* --- ROLE 4: EMPLOYEE (STAFF) --- *@
    @if (Model.User.RoleId == 4 && Model.User.Staff != null)
    {
        <h5 class="section-title"><i class="fa-solid fa-id-badge"></i> Thông tin nhân sự</h5>
        <div class="info-grid">
            <div class="profile-info employee-card" >
                <label>Mã NV:</label> <span>@Model.User.Staff.EmployeeCode</span>
            </div>
            <div class="profile-info employee-card">
                <label>Ngày vào làm:</label> <span>@Model.User.Staff.HireDate?.ToString("dd/MM/yyyy")</span>
            </div>
        </div>
    }

    <div class="btn-group-center">
        <a asp-page="./Edit" asp-route-id="@Model.User.UserId" class="btn-custom btn-edit">
            <i class="fa-solid fa-user-pen"></i> Chỉnh sửa
        </a>

        <a asp-page="/Index" class="btn-custom btn-back">
            <i class="fa-solid fa-house"></i> Trang chủ
        </a>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // 1. Xử lý hiển thị thông báo thành công từ TempData
        document.addEventListener("DOMContentLoaded", function () {
            @if (TempData["Success"] != null)
            {
                <text>
                Swal.fire({
                    title: 'Thành công!',
                    text: '@Html.Raw(TempData["Success"])',
                    icon: 'success',
                    confirmButtonColor: '#28a745',
                    confirmButtonText: 'OK',
                    timer: 3000, // Tự đóng sau 3 giây
                    timerProgressBar: true
                });
                </text>
            }
        });

        // 2. Hàm hỗ trợ xem ảnh phóng to (vẫn giữ lại nếu bạn cần)
        function showImagePopup(url, title) {
            Swal.fire({
                title: title,
                imageUrl: url,
                imageAlt: title,
                showConfirmButton: false,
                showCloseButton: true,
                backdrop: `rgba(0,0,0,0.8)`
            });
        }
    </script>
}