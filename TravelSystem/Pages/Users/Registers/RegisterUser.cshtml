@page
@model TravelSystem.Pages.Users.Registers.RegisterUserModel

<style>
    body {
        background: url('/images/img_7.png') center/cover no-repeat fixed;
    }

    .wrapper {
        max-width: 800px;
        margin: 60px auto 80px;
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        padding: 50px 60px;
    }

        .wrapper h2 {
            color: #28a745;
            margin-bottom: 30px;
            text-align: center;
        }

    .form-label {
        font-weight: 500;
    }

    .required {
        color: red;
        margin-left: 2px;
    }

    .error-message {
        color: #dc3545;
        font-size: 0.82rem;
        margin-top: 3px;
        display: block;
    }

    input[type="password"]::-ms-reveal,
    input[type="password"]::-ms-clear {
        display: none;
    }

    .input-group-text {
        border-left: none;
        background: #f8f9fa;
        cursor: pointer;
    }

    .input-group .form-control {
        border-right: none;
    }

    .btn-save {
        background: #28a745;
        color: white;
        border: none;
        padding: 10px 28px;
        border-radius: 8px;
        font-size: 15px;
        cursor: pointer;
    }

        .btn-save:hover {
            background: #218838;
        }

        .btn-save:disabled {
            background: #6c9e72;
            cursor: not-allowed;
        }

    .btn-agent {
        background: #007bff;
        color: white;
        border: none;
        padding: 10px 28px;
        border-radius: 8px;
        font-size: 15px;
        cursor: pointer;
    }

        .btn-agent:hover {
            background: #0056b3;
        }

        .btn-agent:disabled {
            background: #6699cc;
            cursor: not-allowed;
        }
</style>

<div class="wrapper">
    <h2>Đăng ký tài khoản</h2>

    @if (Model.GeneralError != null)
    {
        <div class="alert alert-danger">@Model.GeneralError</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" id="registerForm">
        <input type="hidden" id="actionInput" name="action" value="" />

        @* Hidden fields giữ password để JS restore vào input type=password *@
        <input type="hidden" id="passwordValue"   value="@Model.User.Password" />
        <input type="hidden" id="repasswordValue" value="@Model.Repassword" />

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Họ <span class="required">*</span></label>
                <input type="text" name="User.LastName" value="@Model.User.LastName"
                       class="form-control" placeholder="Nhập họ" />
                @if (ModelState["User.LastName"]?.Errors.Count > 0)
                {
                    <span class="error-message">@ModelState["User.LastName"].Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="col-md-6">
                <label class="form-label">Tên <span class="required">*</span></label>
                <input type="text" name="User.FirstName" value="@Model.User.FirstName"
                       class="form-control" placeholder="Nhập tên" />
                @if (ModelState["User.FirstName"]?.Errors.Count > 0)
                {
                    <span class="error-message">@ModelState["User.FirstName"].Errors[0].ErrorMessage</span>
                }
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Mật Khẩu <span class="required">*</span></label>
                <div class="input-group">
                    <input type="password" id="password" name="User.Password"
                           class="form-control" placeholder="Nhập mật khẩu" />
                    <span class="input-group-text" onclick="togglePassword('password')">
                        <i class="fas fa-eye"></i>
                    </span>
                </div>
                @if (ModelState["User.Password"]?.Errors.Count > 0)
                {
                    <span class="error-message">@ModelState["User.Password"].Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="col-md-6">
                <label class="form-label">Nhập Lại Mật Khẩu <span class="required">*</span></label>
                <div class="input-group">
                    <input type="password" id="repassword" name="Repassword"
                           class="form-control" placeholder="Nhập lại mật khẩu" />
                    <span class="input-group-text" onclick="togglePassword('repassword')">
                        <i class="fas fa-eye"></i>
                    </span>
                </div>
                @if (ModelState["Repassword"]?.Errors.Count > 0)
                {
                    <span class="error-message">@ModelState["Repassword"].Errors[0].ErrorMessage</span>
                }
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Số Điện Thoại <span class="required">*</span></label>
                <input type="text" name="User.Phone" value="@Model.User.Phone"
                       class="form-control" placeholder="VD: 0901234567" />
                @if (ModelState["User.Phone"]?.Errors.Count > 0)
                {
                    <span class="error-message">@ModelState["User.Phone"].Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="col-md-6">
                <label class="form-label">Ngày Sinh <span class="required">*</span></label>
                <input type="date" name="User.Dob" value="@Model.User.Dob?.ToString("yyyy-MM-dd")"
                       class="form-control" />
                @if (ModelState["User.Dob"]?.Errors.Count > 0)
                {
                    <span class="error-message">@ModelState["User.Dob"].Errors[0].ErrorMessage</span>
                }
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Giới Tính <span class="required">*</span></label>
                <select name="User.Gender" class="form-control">
                    <option value="">-- Chọn giới tính --</option>
                    <option value="Nam" selected="@(Model.User.Gender == "Nam")">Nam</option>
                    <option value="Nữ" selected="@(Model.User.Gender == "Nữ")">Nữ</option>
                </select>
                @if (ModelState["User.Gender"]?.Errors.Count > 0)
                {
                    <span class="error-message">@ModelState["User.Gender"].Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="col-md-6">
                <label class="form-label">Gmail</label>
                <input type="email" name="User.Gmail" value="@Model.User.Gmail"
                       class="form-control" readonly />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Địa Chỉ <span class="required">*</span></label>
            <input type="text" name="User.Address" value="@Model.User.Address"
                   class="form-control" placeholder="Nhập địa chỉ" />
            @if (ModelState["User.Address"]?.Errors.Count > 0)
            {
                <span class="error-message">@ModelState["User.Address"].Errors[0].ErrorMessage</span>
            }
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <button type="button" id="btnRegister" class="btn-save" onclick="submitForm('register')">
                Đăng ký
            </button>
            <button type="button" id="btnAgent" class="btn-agent" onclick="submitForm('becomeAgent')">
                <i class="fas fa-handshake me-1"></i> Trở thành đối tác
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
    <script>
        window.addEventListener('DOMContentLoaded', function () {
            // Restore giá trị password từ hidden field (hoạt động cả khi quay lại từ AgentRegister)
            var pwVal  = document.getElementById('passwordValue').value;
            var rpVal  = document.getElementById('repasswordValue').value;
            if (pwVal)  document.getElementById('password').value   = pwVal;
            if (rpVal)  document.getElementById('repassword').value = rpVal;
        });

        function submitForm(action) {
            document.getElementById('actionInput').value = action;
            document.getElementById('btnRegister').disabled = true;
            document.getElementById('btnAgent').disabled    = true;
            document.getElementById('registerForm').submit();
        }

        function togglePassword(fieldId) {
            var input = document.getElementById(fieldId);
            if (input.type === 'password') {
                input.type = 'text';
                input.parentElement.querySelector('i').classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                input.parentElement.querySelector('i').classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>

    @if (Model.RegisterSuccess)
    {
        <script>
            Swal.fire({
                title: 'Đăng ký thành công!',
                text: 'Tài khoản của bạn đã được tạo.',
                icon: 'success',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<i class="fas fa-sign-in-alt"></i> Đăng nhập',
                cancelButtonText: '<i class="fas fa-home"></i> Trang chủ',
                allowOutsideClick: false,
                width: '700px',
                padding: '8em 2em',
                customClass: { popup: 'swal-large' }
            }).then((result) => {
                window.location.href = result.isConfirmed ? '/Auths/Login' : '/';
            });
        </script>
    }
}
