@page
@model TravelSystem.Pages.Admin.Statistic.IndexModel
<div class="container-fluid p-4">
    <h2 class="mb-4">Quản lý doanh thu</h2>

    <div class="text-center mb-4">
        <h5>Tổng Doanh Thu (Đã Hoàn Thành)</h5>
        <div><strong>@String.Format("{0:N0} đ", Model.TotalRevenue)</strong></div>
        <div>Tổng số đơn đặt: @Model.TotalCompletedOrders</div>
    </div>

    <h5 class="mb-3">Danh Sách Đơn Đặt (Đã Hoàn Thành)</h5>

    <form method="get" class="row align-items-end g-3 mb-3">
        <div class="col-md-3">
            <label class="form-label">Lọc theo ngày</label>
            <select asp-for="DateFilter" class="form-select">
                <option value="all">Tất cả</option>
                <option value="today">Hôm nay</option>
                <option value="month">Tháng này</option>
                <option value="year">Năm nay</option>
            </select>
        </div>

        <div class="col-md-4">
            <label class="form-label">Tìm kiếm</label>
            <input asp-for="SearchTerm" class="form-control" placeholder="Mã đơn / tên tour / khách hàng" />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Lọc</button>
        </div>

        <div class="col-md-2">
            <a asp-page="./Index" class="btn btn-secondary w-100">Đặt lại</a>
        </div>
    </form>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Tên tour</th>
                <th>Khách hàng</th>
                <th>Số tiền thuế</th>
                <th>Số tiền</th>
                <th>Ngày đặt</th>
                <th>Trạng thái</th>
                <th>Hoạt động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Orders.Any())
            {
                foreach (var item in Model.Orders)
                {
                    <tr>
                        <td>@item.BookCode</td>
                        <td>@item.TourName</td>
                        <td>@item.CustomerName</td>
                        <td>@String.Format("{0:N0} đ", item.TaxAmount)</td>
                        <td>@String.Format("{0:N0} đ", item.TotalPrice)</td>
                        <td>@item.BookDate?.ToString("dd/MM/yyyy")</td>
                        <td>@item.StatusText</td>
                        <td>
                            <a asp-page="./Details" asp-route-id="@item.BookId" class="btn btn-info btn-sm">
                                Chi tiết
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">Không có dữ liệu.</td>
                </tr>
            }
        </tbody>
    </table>

    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link"
                       asp-page="./Index"
                       asp-route-pageNumber="@i"
                       asp-route-dateFilter="@Model.DateFilter"
                       asp-route-searchTerm="@Model.SearchTerm">
                        @i
                    </a>
                </li>
            }
        </ul>
    </nav>
</div>
