@page
@model TravelSystem.Pages.Admin.Withdraw.WithdrawManagementModel
@{
    ViewData["Title"] = "Quản lý yêu cầu rút tiền";
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<style>
    body {
        background: #f8f9fa;
        font-family: 'Segoe UI', sans-serif;
    }

    .main-container {
        background: #fff;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.05);
        margin-top: 30px;
    }

    .badge-pending {
        background-color: #ffc107;
        color: #000;
        padding: 5px 10px;
        border-radius: 4px;
    }

    .badge-approved {
        background-color: #198754;
        color: #fff;
        padding: 5px 10px;
        border-radius: 4px;
    }

    .badge-rejected {
        background-color: #dc3545;
        color: #fff;
        padding: 5px 10px;
        border-radius: 4px;
    }
</style>

<div id="SideNavAdmin" class="d-flex">

    <div id="SideNavAdmin" class="flex-grow-1 px-4">
        <div class="main-container">
            <h2 class="mb-4">Quản lý yêu cầu rút tiền</h2>

            <div class="d-flex align-items-center mb-4 flex-wrap">
                <form method="get" class="d-flex align-items-center me-auto mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <input type="text" name="keyword" class="form-control me-2" placeholder="Nhập email..." value="@Model.Keyword" />
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-search"></i> Tìm kiếm
                        </button>
                    </div>
                </form>

                <form method="get" class="d-flex align-items-center mb-2">
                    <label for="status" class="me-2 mb-0 fw-bold">Lọc theo trạng thái:</label>
                    <select name="status" id="status" class="form-select" style="width: 200px;" onchange="this.form.submit()">
                        <option value="">Tất cả</option>
                        <!option value="PENDING" @(Model.Status == "PENDING" ? "selected" : "")>Chờ xử lý</!option>
                        <!option value="APPROVED" @(Model.Status == "APPROVED" ? "selected" : "")>Đã duyệt</!option>
                        <!option value="REJECTED" @(Model.Status == "REJECTED" ? "selected" : "")>Từ chối</!option>
                    </select>
                </form>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="table-light text-center">
                        <tr>
                            <th>STT</th>
                            <th>Tài khoản</th>
                            <th>Ngân hàng</th>
                            <th>Số tài khoản</th>
                            <th>Số tiền</th>
                            <th>Ngày tạo</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.WithdrawList != null && Model.WithdrawList.Any())
                        {
                            int index = (Model.CurrentPage - 1) * 10 + 1;
                            foreach (var item in Model.WithdrawList)
                            {
                                <tr>
                                    <td class="text-center">@(index++)</td>
                                    <td>@item.Email</td>
                                    <td class="text-center">@item.BankName</td>
                                    <td>@item.BankAccountNumber</td>
                                    <td class="text-end fw-bold">@item.Amount.ToString("N0") VNĐ</td>
                                    <td class="text-center">@item.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        @if (item.Status == "APPROVED")
                                        {
                                            <span class="badge-approved">Đã duyệt</span>
                                        }
                                        else if (item.Status == "REJECTED")
                                        {
                                            <span class="badge-rejected">Từ chối</span>
                                        }
                                        else
                                        {
                                            <span class="badge-pending">Chờ xử lý</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-page="./WithdrawDetail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fa fa-eye"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">Không tìm thấy yêu cầu nào phù hợp.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="?page=@i&keyword=@Model.Keyword&status=@Model.Status">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>