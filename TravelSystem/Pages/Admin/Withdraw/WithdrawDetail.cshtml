@page
@model TravelSystem.Pages.Staff.WithdrawDetailModel
@{
    ViewData["Title"] = "Chi tiết rút tiền";
    Layout = "_Layout";
}

<style>
    .img-preview {
        max-width: 100%;
        border: 1px solid #ddd;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.3s;
    }

        .img-preview:hover {
            opacity: 0.8;
        }

    .info-label {
        font-weight: bold;
        color: #555;
        width: 150px;
        display: inline-block;
    }
</style>

<div class="container-fluid px-4 mt-4 mb-5">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="./WithdrawManagement" class="btn btn-outline-secondary me-3">
            <i class="fa fa-arrow-left"></i> Quay lại
        </a>
        <h3 class="mb-0">Chi tiết yêu cầu rút tiền</h3>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><span class="info-label">Email:</span> @Model.Withdraw.Email</p>
                    <p><span class="info-label">Ngân hàng:</span> @Model.Withdraw.BankName</p>
                    <p><span class="info-label">Số tài khoản:</span> <code>@Model.Withdraw.BankAccountNumber</code></p>
                    <p><span class="info-label">Chủ tài khoản:</span> @Model.Withdraw.AccountHolderName</p>
                    <p><span class="info-label">Số tiền:</span> <span class="text-danger fw-bold">@Model.Withdraw.Amount.ToString("N0") VNĐ</span></p>
                </div>
                <div class="col-md-6">
                    <p><span class="info-label">Số điện thoại:</span> @Model.Withdraw.Phone</p>
                    <p><span class="info-label">CCCD:</span> @Model.Withdraw.IdCard</p>
                    <p><span class="info-label">Ngày tạo:</span> @Model.Withdraw.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                    <p>
                        <span class="info-label">Trạng thái:</span>
                        @switch (Model.Withdraw.Status)
                        {
                            case "APPROVED":
                                <span class="badge bg-success">Đã duyệt</span>
                                break;
                            case "REJECTED":

                                <span class="badge bg-danger">Từ chối</span>
                                break;
                            default:

                                <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                break;
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <label class="fw-bold mb-2">Ảnh CCCD mặt trước:</label>
            <img src="~/@Model.Withdraw.IdCardFrontImage" class="img-preview" data-bs-toggle="modal" data-bs-target="#imageModal" onclick="setModalImg(this.src)" />
        </div>
        <div class="col-md-6">
            <label class="fw-bold mb-2">Ảnh CCCD mặt sau:</label>
            <img src="~/@Model.Withdraw.IdCardBackImage" class="img-preview" data-bs-toggle="modal" data-bs-target="#imageModal" onclick="setModalImg(this.src)" />
        </div>
    </div>

    @if (Model.Withdraw.Status == "PENDING")
    {
        <div class="d-flex gap-2">
            <button class="btn btn-success px-4" onclick="confirmApprove(@Model.Withdraw.Id)">
                <i class="fa fa-check me-1"></i> Duyệt yêu cầu
            </button>
            <button class="btn btn-danger px-4" data-bs-toggle="modal" data-bs-target="#rejectModal">
                <i class="fa fa-times me-1"></i> Từ chối
            </button>
        </div>
    }
</div>

<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark">
            <div class="modal-body p-0 text-center">
                <img id="modalImg" src="" class="img-fluid" style="max-height: 90vh;" />
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form method="post" class="modal-content">
            <input type="hidden" name="id" value="@Model.Withdraw.Id" />
            <input type="hidden" name="action" value="reject" />
            <div class="modal-header">
                <h5 class="modal-title">Lý do từ chối</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <textarea class="form-control" name="reason" rows="4" required placeholder="Nhập lý do gửi đến khách hàng..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-danger">Xác nhận từ chối</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function setModalImg(src) { document.getElementById('modalImg').src = src; }

                function confirmApprove(id) {
            Swal.fire({
                title: 'Xác nhận duyệt?',
                text: "Tiền sẽ được trừ trực tiếp từ ví người dùng và hệ thống!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Đồng ý duyệt'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'post';

                    // Lấy Antiforgery Token có sẵn trên trang
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    form.innerHTML = `
                        <input type="hidden" name="__RequestVerificationToken" value="${token}">
                        <input type="hidden" name="id" value="${id}">
                        <input type="hidden" name="action" value="approve">
                    `;
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
}