@page
@model TravelSystem.Pages.Admin.Dashboard.IndexModel
@using System.Text.Json

<div class="container-fluid p-4">
    <h1 class="mb-4 fw-bold">Bảng Điều Khiển Quản Trị</h1>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-primary text-uppercase small fw-semibold">Tổng số tài khoản</div>
                        <div class="fs-2 fw-bold">@Model.TotalAccounts</div>
                    </div>
                    <i class="fa-solid fa-users fs-1 text-dark"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-success text-uppercase small fw-semibold">Số đại lý du lịch</div>
                        <div class="fs-2 fw-bold">@Model.TotalAgents</div>
                    </div>
                    <i class="fa-solid fa-briefcase fs-1 text-dark"></i>
                </div>
            </div>
        </div>

        @* Nếu muốn hiện lại card staff thì bỏ comment khối này
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-info text-uppercase small fw-semibold">Số nhân viên</div>
                        <div class="fs-2 fw-bold">@Model.TotalStaffs</div>
                    </div>
                    <i class="fa-solid fa-user-tie fs-1 text-dark"></i>
                </div>
            </div>
        </div>
        *@

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-warning text-uppercase small fw-semibold">Số khách du lịch</div>
                        <div class="fs-2 fw-bold">@Model.TotalTourists</div>
                    </div>
                    <i class="fa-solid fa-globe fs-1 text-dark"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-danger text-uppercase small fw-semibold">Tổng doanh thu</div>
                        <div class="fs-2 fw-bold">@String.Format("{0:N0}", Model.TotalRevenue)</div>
                    </div>
                    <i class="fa-solid fa-dollar-sign fs-1 text-dark"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-secondary text-uppercase small fw-semibold">Tổng số tour</div>
                        <div class="fs-2 fw-bold">@Model.TotalTours</div>
                    </div>
                    <i class="fa-solid fa-map fs-1 text-dark"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-semibold">
            <i class="fa-solid fa-chart-pie me-2"></i> Phân Bố Tài Khoản
        </div>
        <div class="card-body">
            <div style="max-width: 500px; margin: 0 auto;">
                <canvas id="accountPieChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const accountLabels = @Html.Raw(JsonSerializer.Serialize(Model.ChartLabels));
        const accountData = @Html.Raw(JsonSerializer.Serialize(Model.ChartData));

        const ctx = document.getElementById('accountPieChart');

        new Chart(ctx, {
            type: 'pie',
            data: {
                labels: accountLabels,
                datasets: [{
                    data: accountData,
                    backgroundColor: ['#28a745', '#17a2b8', '#ffc107'],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'top'
                    }
                }
            }
        });
    </script>
}