@page
@model TravelSystem.Pages.Admin.Payment.HistoryPaymentWalletSystemModel
@{
    ViewData["Title"] = "Lịch sử giao dịch hệ thống";
}

<div class="container-fluid px-4 mt-5">
   

    <h2 class="mb-4 fw-bold">Lịch sử giao dịch hệ thống</h2>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-lg-7">
                    <form method="get" id="filterForm" class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="small mb-1 fw-bold">Từ ngày:</label>
                            <input type="date" asp-for="FromDate" class="form-control" id="fromDate" />
                        </div>
                        <div class="col-md-4">
                            <label class="small mb-1 fw-bold">Đến ngày:</label>
                            <input type="date" asp-for="ToDate" class="form-control" id="toDate" />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fa fa-filter me-1"></i> Lọc ngày
                            </button>
                        </div>
                        <input type="hidden" name="Status" value="@Model.Status" />
                    </form>
                </div>

                <div class="col-lg-5">
                    <form method="get" class="row g-2 align-items-end justify-content-end">
                        <div class="col-md-8">
                            <label class="small mb-1 fw-bold">Loại giao dịch:</label>
                            <select asp-for="Status" class="form-select" onchange="this.form.submit()">
                                <option value="0">-- Tất cả loại --</option>
                                <option value="ADJUSTMENT">Hoàn tiền du khách</option>
                                <option value="RECEIVE">Người dùng nạp tiền</option>
                                <option value="PURCHASE">Người dùng rút tiền</option>
                                <option value="REFUND">Trả tiền đại lí</option>
                            </select>
                        </div>
                        <input type="hidden" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />

                        <div class="col-md-4">
                            <a asp-page="./HistoryPaymentWalletSystem" class="btn btn-outline-secondary w-100">
                                <i class="fa fa-undo me-1"></i> Xóa lọc
                            </a>
                        </div>
                    </form>
                </div>
            </div>
            <div id="dateError" class="text-danger mt-2 small fw-bold"></div>
        </div>
    </div>

    <div class="table-responsive shadow-sm bg-white rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="text-center">STT</th>
                    <th>Ngày giao dịch</th>
                    <th>Nội dung</th>
                    <th class="text-center">Loại giao dịch</th>
                    <th class="text-end">Số tiền</th>
                    <th class="text-end">Số dư sau GD</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.TransactionList.Any())
                {
                    int i = Model.StartIndex;
                    foreach (var tx in Model.TransactionList)
                    {
                        <tr>
                            <td class="text-center">@(i++)</td>
                            <td>@tx.TransactionDate?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@tx.Description</td>
                            <td class="text-center">
                                @switch (tx.TransactionType)
                                {
                                    case "ADJUSTMENT":
                                        <span class="badge bg-info text-dark">Hoàn tiền du khách</span>
                                        break;
                                    case "RECEIVE":

                                        <span class="badge bg-success">Người dùng nạp tiền</span>
                                        break;
                                    case "PURCHASE":

                                        <span class="badge bg-danger">Người dùng rút tiền</span>
                                        break;
                                    case "REFUND":

                                        <span class="badge bg-warning text-dark">Trả tiền đại lí</span>
                                        break;
                                    default:

                                        <span class="badge bg-secondary">@tx.TransactionType</span>
                                        break;
                                }
                            </td>
                            <td class="text-end fw-bold text-primary">@tx.Amount.ToString("N0") VNĐ</td>
                            <td class="text-end fw-bold">@tx.AmountAfterTransaction?.ToString("N0") VNĐ</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Không tìm thấy giao dịch nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

        <nav class="mt-4 pb-5">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-FromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                       asp-route-ToDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                       asp-route-Status="@Model.Status">Trước</a>
                </li>
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-route-page="@p"
                           asp-route-FromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                           asp-route-ToDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                           asp-route-Status="@Model.Status">@p</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-FromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                       asp-route-ToDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                       asp-route-Status="@Model.Status">Sau</a>
                </li>
            </ul>
        </nav>
    
</div>

@section Scripts {
    <script>
        document.getElementById("filterForm").addEventListener("submit", function (e) {
            const fromDate = document.getElementById("fromDate").value;
            const toDate = document.getElementById("toDate").value;
            const errorDiv = document.getElementById("dateError");

            errorDiv.textContent = "";

            if (fromDate && toDate && new Date(toDate) < new Date(fromDate)) {
                e.preventDefault();
                errorDiv.textContent = "Ngày kết thúc không được trước ngày bắt đầu.";
            }
        });
    </script>
}