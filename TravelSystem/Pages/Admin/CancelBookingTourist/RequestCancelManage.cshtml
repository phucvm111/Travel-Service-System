@page
@model TravelSystem.Pages.Admin.Requests.RequestCancelManageModel
@{
    Layout = "_Layout"; // Sử dụng layout chung đã fix rộng ở trên
    ViewData["Title"] = "Quản lý yêu cầu hủy chuyến";
}

<div class="container-fluid pt-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
            <h2 class="mb-4 fw-bold text-dark">Quản lý yêu cầu huỷ chuyến đi</h2>

            <div class="row g-3 mb-4 align-items-end">
                <div class="col-md-6">
                    <form method="get" class="d-flex gap-2">
                        <input type="text" name="Keyword" class="form-control" placeholder="Nhập email khách hàng..." value="@Model.Keyword" />
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fa fa-search"></i> Tìm kiếm
                        </button>
                    </form>
                </div>
                <div class="col-md-6 text-md-end">
                    <form method="get" class="d-inline-flex align-items-center gap-2">
                        <label class="fw-bold text-nowrap">Trạng thái:</label>
                        <select name="Status" class="form-select" style="width: 200px;" onchange="this.form.submit()">
                            <option value="">Tất cả</option>
                            <!option value="PENDING" @(Model.Status == "PENDING" ? "selected" : "")>Chờ xử lý</!option>
                            <!option value="FINISHED" @(Model.Status == "FINISHED" ? "selected" : "")>Đã duyệt</!option>
                            <!option value="REJECTED" @(Model.Status == "REJECTED" ? "selected" : "")>Đã từ chối</!option>
                        </select>
                    </form>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle border">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center">STT</th>
                            <th>Email khách hàng</th>
                            <th>Lý do hủy</th>
                            <th>Ngày yêu cầu</th>
                            <th>Ngày khởi hành</th>
                            <th class="text-end">Tiền hoàn trả</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListRequest.Any())
                        {
                            int index = (Model.CurrentPage - 1) * 10 + 1;
                            foreach (var item in Model.ListRequest)
                            {
                                <tr>
                                    <td class="text-center">@(index++)</td>
                                    <td class="fw-semibold">@item.Request.Book?.Gmail</td>
                                    <td style="max-width: 250px;" class="text-truncate">@item.Request.Reason</td>
                                    <td>@item.Request.RequestDate?.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Request.Book?.Tour?.StartDay?.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end fw-bold text-danger">@item.RefundAmount.ToString("N0") VNĐ</td>
                                    <td class="text-center">
                                        @if (item.Request.Status == "PENDING")
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Chờ xử lý</span>
                                        }
                                        else if (item.Request.Status == "FINISHED")
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill">Đã duyệt</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-3 py-2 rounded-pill">Đã từ chối</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-page="./RequestCancelDetail" asp-route-id="@item.Request.RequestCancelId" class="btn btn-sm btn-outline-primary">
                                            <i class="fa fa-eye"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">Không tìm thấy yêu cầu nào phù hợp.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-route-page="@i" asp-route-keyword="@Model.Keyword" asp-route-status="@Model.Status">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<style>
    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .badge {
        font-weight: 500;
        font-size: 0.8rem;
    }

    .page-link {
        color: #f50057;
    }

    .page-item.active .page-link {
        background-color: #f50057;
        border-color: #f50057;
    }
</style>