@page
@model TravelSystem.Pages.Admin.CancelBookingTourist.RequestCancelDetailModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết yêu cầu hủy";
}

<div class="container-fluid pt-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-page="./RequestCancelManage" class="btn btn-secondary me-3">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h3 class="mb-0 fw-bold">Chi tiết yêu cầu hủy chuyến đi</h3>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="border-bottom pb-2 mb-3 text-primary">Thông tin đặt chỗ</h5>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Mã đặt tour:</div>
                        <div class="col-sm-8 text-danger fw-bold">#@Model.RequestDetail.Book?.BookCode</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Tên chuyến đi:</div>
                        <div class="col-sm-8">@Model.RequestDetail.Book?.Tour?.TourName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Khách hàng:</div>
                        <div class="col-sm-8">@Model.RequestDetail.Book?.Gmail</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Ngày khởi hành:</div>
                        <div class="col-sm-8">@Model.RequestDetail.Book?.Tour?.StartDay?.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Tổng giá trị đơn:</div>
                        <div class="col-sm-8">@Model.RequestDetail.Book?.TotalPrice?.ToString("N0") VNĐ</div>
                    </div>
                    <div class="row mb-3 p-3 bg-light rounded">
                        <div class="col-sm-4 fw-bold text-success">Số tiền hoàn trả dự kiến:</div>
                        <div class="col-sm-8 h5 mb-0 fw-bold text-success">@Model.RefundAmount.ToString("N0") VNĐ</div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="border-bottom pb-2 mb-3 text-warning">Chi tiết yêu cầu</h5>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Ngày gửi yêu cầu:</div>
                        <div class="col-sm-8">@Model.RequestDetail.RequestDate?.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Lý do hủy:</div>
                        <div class="col-sm-8">@Model.RequestDetail.Reason</div>
                    </div>
                    <div class="row mb-3 border-top pt-3">
                        <div class="col-sm-4 fw-bold">Trạng thái hiện tại:</div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.RequestDetail.Status == "PENDING" ? "bg-warning" : Model.RequestDetail.Status == "FINISHED" ? "bg-success" : "bg-danger") px-3 py-2">
                                @Model.RequestDetail.Status
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            @if (Model.RequestDetail.Status == "PENDING")
            {
                <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                    <div class="card-body p-4 text-center">
                        <h5 class="mb-4">Xử lý yêu cầu</h5>
                        <button type="button" class="btn btn-success w-100 mb-3 py-2" data-bs-toggle="modal" data-bs-target="#approveModal">
                            <i class="bi bi-check-circle me-2"></i> Duyệt & Hoàn tiền
                        </button>
                        <button type="button" class="btn btn-outline-danger w-100 py-2" data-bs-toggle="modal" data-bs-target="#rejectModal">
                            <i class="bi bi-x-circle me-2"></i> Từ chối yêu cầu
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="approveModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Approve" class="modal-content">
            <input type="hidden" name="requestCancelID" value="@Model.RequestDetail.RequestCancelId" />
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Xác nhận duyệt hoàn tiền</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <p class="mb-1 text-muted">Số tiền sẽ được cộng vào ví khách hàng:</p>
                <h2 class="text-success fw-bold">@Model.RefundAmount.ToString("N0") VNĐ</h2>
                <p class="mt-3 small">Hành động này không thể hoàn tác. Bạn có chắc chắn muốn duyệt?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-success px-4">Xác nhận Duyệt</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Reject" class="modal-content">
            <input type="hidden" name="requestCancelID" value="@Model.RequestDetail.RequestCancelId" />
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Từ chối yêu cầu hủy</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label fw-bold">Lý do từ chối:</label>
                <textarea class="form-control" name="rejectReason" rows="4" required placeholder="Nhập lý do gửi cho khách hàng..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Đóng</button>
                <button type="submit" class="btn btn-danger px-4">Gửi từ chối</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('approve') === 'true') {
            Swal.fire('Thành công', 'Đã duyệt và hoàn tiền vào ví khách hàng!', 'success');
        } else if (urlParams.get('reject') === 'true') {
            Swal.fire('Đã từ chối', 'Yêu cầu đã bị từ chối thành công.', 'info');
        }
    </script>
}