@page "{id:int}"
@model YourProject.Pages.Admin.Vouchers.EditModel
@{
    ViewData["Title"] = "Cập nhật thẻ khuyến mãi";
}

<h2>Cập nhật thẻ khuyến mãi</h2>

<form method="post">
    <input type="hidden" asp-for="Voucher.VoucherId" />

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Voucher.VoucherCode" class="form-label">Mã thẻ</label>
            <input asp-for="Voucher.VoucherCode" class="form-control" />
            <span asp-validation-for="Voucher.VoucherCode" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Voucher.VoucherName" class="form-label">Tên thẻ</label>
            <input asp-for="Voucher.VoucherName" class="form-control" />
            <span asp-validation-for="Voucher.VoucherName" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Voucher.Description" class="form-label">Mô tả</label>
        <textarea asp-for="Voucher.Description" class="form-control"></textarea>
        <span asp-validation-for="Voucher.Description" class="text-danger"></span>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Voucher.PercentDiscount" class="form-label">Phần trăm khuyến mãi</label>
            <input asp-for="Voucher.PercentDiscount" class="form-control" />
            <span asp-validation-for="Voucher.PercentDiscount" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Voucher.Quantity" class="form-label">Số lượng</label>
            <input asp-for="Voucher.Quantity" class="form-control" />
            <span asp-validation-for="Voucher.Quantity" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Voucher.MaxDiscountAmount" class="form-label">Giảm tối đa</label>
            <input asp-for="Voucher.MaxDiscountAmount" class="form-control" />
            <span asp-validation-for="Voucher.MaxDiscountAmount" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Voucher.MinAmountApply" class="form-label">Giá tối thiểu áp dụng</label>
            <input asp-for="Voucher.MinAmountApply" class="form-control" />
            <span asp-validation-for="Voucher.MinAmountApply" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Voucher.StartDate" class="form-label">Ngày bắt đầu</label>
            <input asp-for="Voucher.StartDate" type="date" class="form-control" />
            <span asp-validation-for="Voucher.StartDate" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Voucher.EndDate" class="form-label">Ngày kết thúc</label>
            <input asp-for="Voucher.EndDate" type="date" class="form-control" />
            <span asp-validation-for="Voucher.EndDate" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Voucher.Status" class="form-label">Trạng thái</label>
        <select asp-for="Voucher.Status" class="form-select">
            <option value="1">Hoạt động</option>
            <option value="0">Không hoạt động</option>
        </select>
        <span asp-validation-for="Voucher.Status" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Sửa</button>
    <a asp-page="/Admin/Vouchers/Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}