@page "{id:int}"
@model TravelSystem.Pages.Staffs.Vouchers.EditModel

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Chỉnh sửa thẻ khuyến mãi</h2>
        <a asp-page="./Index" class="btn btn-secondary">Trở lại</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <form method="post" onsubmit="return confirm('Bạn có chắc muốn cập nhật voucher này không?');">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Voucher.VoucherId" />
        <input type="hidden" asp-for="Voucher.UserId" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Voucher.VoucherCode" class="form-label">Mã voucher</label>
                <input asp-for="Voucher.VoucherCode" class="form-control" placeholder="VD: SUMMER25" />
                <span asp-validation-for="Voucher.VoucherCode" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Voucher.VoucherName" class="form-label">Tên voucher</label>
                <input asp-for="Voucher.VoucherName" class="form-control" />
                <span asp-validation-for="Voucher.VoucherName" class="text-danger"></span>
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="Voucher.Description" class="form-label">Mô tả</label>
                <textarea asp-for="Voucher.Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Voucher.Description" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Voucher.PercentDiscount" class="form-label">Phần trăm giảm giá (%)</label>
                <input asp-for="Voucher.PercentDiscount" type="number" step="0.01" min="0" max="100" class="form-control" />
                <span asp-validation-for="Voucher.PercentDiscount" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Voucher.MaxDiscountAmount" class="form-label">Giảm tối đa</label>
                <input asp-for="Voucher.MaxDiscountAmount" type="number" step="0.01" min="0" class="form-control" />
                <span asp-validation-for="Voucher.MaxDiscountAmount" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Voucher.MinDiscountAmount" class="form-label">Giá trị đơn tối thiểu</label>
                <input asp-for="Voucher.MinDiscountAmount" type="number" step="0.01" min="0" class="form-control" />
                <span asp-validation-for="Voucher.MinDiscountAmount" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Voucher.StartDate" class="form-label">Ngày bắt đầu</label>
                <input asp-for="Voucher.StartDate" type="date" class="form-control" />
                <span asp-validation-for="Voucher.StartDate" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Voucher.EndDate" class="form-label">Ngày kết thúc</label>
                <input asp-for="Voucher.EndDate" type="date" class="form-control" />
                <span asp-validation-for="Voucher.EndDate" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Voucher.Quantity" class="form-label">Số lượng</label>
                <input asp-for="Voucher.Quantity" type="number" min="0" max="100" class="form-control" />
                <span asp-validation-for="Voucher.Quantity" class="text-danger"></span>
            </div>

            @* <div class="col-md-4 mb-3">
                <label asp-for="Voucher.Status" class="form-label">Trạng thái</label>
                <select asp-for="Voucher.Status" class="form-select">
                    <option value="1">Hoạt động</option>
                    <option value="0">Ngừng hoạt động</option>
                    <option value="2">Chờ duyệt</option>
                </select>
                <span asp-validation-for="Voucher.Status" class="text-danger"></span>
            </div> *@
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a asp-page="./Index" class="btn btn-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}