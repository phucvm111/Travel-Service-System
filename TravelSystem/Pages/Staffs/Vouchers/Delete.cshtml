@page "{id:int}"
@model TravelSystem.Pages.Staffs.Vouchers.DeleteModel

<div class="container-fluid p-4">
    <div class="mb-3">
        <h2>Thay đổi trạng thái voucher</h2>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (Model.Voucher != null)
    {
        var newStatusText = Model.Voucher.Status == 1 ? "Ngừng hoạt động" : "Hoạt động";

        <div class="card shadow-sm">
            <div class="card-body">
                <h4 class="mb-3">Xác nhận thay đổi trạng thái</h4>

                <p>
                    Bạn có chắc chắn muốn thay đổi trạng thái voucher
                    <strong>@Model.Voucher.VoucherCode</strong>
                    thành <strong>@newStatusText</strong> không?
                </p>

                <div class="row mb-2">
                    <div class="col-md-3 fw-bold">Mã voucher:</div>
                    <div class="col-md-9">@Model.Voucher.VoucherCode</div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-3 fw-bold">Tên voucher:</div>
                    <div class="col-md-9">@Model.Voucher.VoucherName</div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-3 fw-bold">Trạng thái hiện tại:</div>
                    <div class="col-md-9">
                        @if (Model.Voucher.Status == 1)
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ngừng hoạt động</span>
                        }
                    </div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-3 fw-bold">Ngày hết hạn:</div>
                    <div class="col-md-9">
                        @(Model.Voucher.EndDate?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="ChangeReason" class="form-label">Lý do thay đổi (không bắt buộc)</label>
                    <textarea asp-for="ChangeReason" class="form-control" rows="3" placeholder="Nhập lý do thay đổi trạng thái..."></textarea>
                </div>

                <form method="post" class="mt-4">
                    <input type="hidden" name="id" value="@Model.Voucher.VoucherId" />
                    <button type="submit" class="btn btn-danger">Xác nhận</button>
                    <a asp-page="./Index" class="btn btn-secondary">Hủy</a>
                </form>
            </div>
        </div>
    }
</div>