@page
@model TravelSystem.Pages.Staffs.Vouchers.IndexModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Quản lý thẻ khuyến mãi</h2>
    <a asp-page="./Create" class="btn btn-success">Thêm thẻ khuyến mãi</a>
</div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4">
            <input asp-for="SearchCode" class="form-control" placeholder="Tìm theo mã voucher..." />
        </div>

        <div class="col-md-3">
            <select asp-for="StatusFilter" class="form-select">
                <option value="">-- Lọc theo trạng thái --</option>
                <option value="1">Hoạt động</option>
                <option value="0">Ngừng hoạt động</option>
            </select>
        </div>

        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
            <a asp-page="./Index" class="btn btn-secondary">Xóa lọc</a>
        </div>
    </form>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <table class="table table-bordered table-striped align-middle">
        <thead class="table-light">
            <tr>
                <th>STT</th>
                <th>Mã voucher</th>
                <th>Tên voucher</th>
                <th>% giảm giá</th>
                <th>Giảm tối đa</th>
                <th>Áp dụng tối thiểu</th>
                <th>Ngày bắt đầu</th>
                <th>Ngày kết thúc</th>
                <th>Số lượng</th>
                <th>Trạng thái</th>
                <th style="width:180px;">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @{
                int stt = (Model.PageNumber - 1) * Model.PageSize;
            }

            @if (Model.Vouchers.Any())
            {
                foreach (var item in Model.Vouchers)
                {
                    stt++;
                    <tr>
                        <td>@stt</td>
                        <td>@item.VoucherCode</td>
                        <td>@item.VoucherName</td>
                        <td>@(item.PercentDiscount.HasValue? item.PercentDiscount.Value.ToString("0.##") + "%" : "Chưa cập nhật")</td>
                        <td>@(item.MaxDiscountAmount.HasValue? item.MaxDiscountAmount.Value.ToString("N0") : "Chưa cập nhật")</td>
                        <td>@(item.MinDiscountAmount.HasValue? item.MinDiscountAmount.Value.ToString("N0") : "Chưa cập nhật")</td>
                        <td>@(item.StartDate?.ToString("dd/MM/yyyy"))</td>
                        <td>@(item.EndDate?.ToString("dd/MM/yyyy"))</td>
                        <td>@(item.Quantity.HasValue? item.Quantity.Value.ToString() : "Chưa cập nhật")</td>
                        <td>
                            @if (item.Status == 1)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ngừng hoạt động</span>
                            }
                        </td>
                    <td>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-page="./Details" asp-route-id="@item.VoucherId" class="btn btn-info btn-sm text-white">
                                Chi tiết
                            </a>
                            <a asp-page="./Delete" asp-route-id="@item.VoucherId" class="btn btn-danger btn-sm">
                                Đổi trạng thái
                            </a>
                        </div>
                    </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="11" class="text-center">Không có voucher nào.</td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link"
                           asp-page="./Index"
                           asp-route-pageNumber="@i"
                           asp-route-searchCode="@Model.SearchCode"
                           asp-route-statusFilter="@Model.StatusFilter">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>