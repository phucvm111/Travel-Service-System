@page
@model TravelSystem.Pages.Staffs.Withdraws.WithdrawManagementModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản lý yêu cầu rút tiền";
}

<div id="layoutSidenav">

    <div id="layoutSidenav_content">
        <main class="container-fluid px-4 mt-5">
            <h2 class="mb-4 fw-bold text-dark">Quản lý yêu cầu rút tiền</h2>

            <div class="card mb-4 shadow-sm border-0">
                <div class="card-body">
                    <form method="get" class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="input-group">
                                <input type="text" name="Keyword" class="form-control" placeholder="Nhập email người rút..." value="@Model.Keyword" />
                                <button type="submit" class="btn btn-primary"><i class="fa fa-search"></i></button>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <select name="Status" class="form-select" onchange="this.form.submit()">
                                <option value="">-- Tất cả trạng thái --</option>
                                <option value="PENDING" selected="@(Model.Status == "PENDING")">Đang chờ</option>
                                <option value="APPROVED" selected="@(Model.Status == "APPROVED")">Đã duyệt</option>
                                <option value="REJECTED" selected="@(Model.Status == "REJECTED")">Đã từ chối</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <a asp-page="./WithdrawManagement" class="btn btn-outline-secondary w-100">Xóa lọc</a>
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle border">
                            <thead class="table-light text-center">
                                <tr>
                                    <th>STT</th>
                                    <th>Email người rút</th>
                                    <th>Số tiền</th>
                                    <th>Ngân hàng (Snapshot)</th>
                                    <th>Số tài khoản</th>
                                    <th>Ngày yêu cầu</th>
                                    <th>Trạng thái</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.WithdrawList != null && Model.WithdrawList.Any())
                                {
                                    int count = (Model.CurrentPage - 1) * 10 + 1;
                                    foreach (var item in Model.WithdrawList)
                                    {
                                        <tr>
                                            <td class="text-center">@(count++)</td>
                                            <td class="fw-bold">@item.CreateByNavigation?.Gmail</td>
                                            <td class="text-danger fw-bold">@item.Amount?.ToString("N0") đ</td>
                                            <td>@item.BankNameSnapshot</td>
                                            <td>@item.BankAccountSnapshot</td>
                                            <td class="text-center small">@item.RequestDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-center">
                                                @if (item.Status == "PENDING")
                                                {
                                                    <span class="badge bg-warning text-dark">Đang chờ</span>
                                                }
                                                else if (item.Status == "APPROVED")
                                                {

                                                    <span class="badge bg-success">Đã duyệt</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-danger">Đã từ chối</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @* Hùng nên tạo trang Detail để thực hiện Duyệt/Từ chối *@
                                                <a asp-page="./WithdrawDetail" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                                                    <i class="fa fa-eye"></i> Xử lý
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="text-center py-4 text-muted">Không tìm thấy yêu cầu rút tiền nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-4">
                            <ul class="pagination justify-content-center">
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" asp-page="./WithdrawManagement" asp-route-p="@i"
                                           asp-route-Keyword="@Model.Keyword" asp-route-Status="@Model.Status">@i</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </main>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var msg = '@Html.Raw(TempData["SuccessMessage"])';

        if (msg && msg !== '') {
            Swal.fire({
                title: 'Thông báo',
                text: msg,
                icon: 'success',
                confirmButtonColor: '#28a745',
                timer: 3000,
                timerProgressBar: true
            });
        }
    </script>
}