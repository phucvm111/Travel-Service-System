@page
@model TravelSystem.Pages.Staffs.RequestCancelManageModel
@{
    Layout = "_Layout"; // Hoặc _LayoutAdmin tùy theo project của bạn
    ViewData["Title"] = "Quản lý yêu cầu hủy";
}

<div id="layoutSidenav">

    <div id="layoutSidenav_content">
        <main>
            <div class="container-fluid px-4">
                <h2 class="mt-4 fw-bold text-primary">Quản lý yêu cầu huỷ chuyến đi</h2>
                <hr />

                <div class="card mb-4 shadow-sm border-0">
                    <div class="card-body">
                        <form method="get" class="row g-3 mb-4 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Tìm theo Email</label>
                                <input type="text" name="Keyword" class="form-control" placeholder="Nhập email khách..." value="@Model.Keyword">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold">Trạng thái</label>
                                <select name="Status" class="form-select" onchange="this.form.submit()">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="PENDING" selected="@(Model.Status == "PENDING")">Chờ xử lý</option>
                                    <option value="FINISHED" selected="@(Model.Status == "FINISHED")">Đã duyệt</option>
                                    <option value="REJECTED" selected="@(Model.Status == "REJECTED")">Đã từ chối</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-filter me-1"></i> Lọc
                                </button>
                            </div>
                        </form>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle border">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-center">STT</th>
                                        <th>Email Khách</th>
                                        <th>Lý do hủy</th>
                                        <th>Ngày yêu cầu</th>
                                        <th>Số tiền hoàn</th>
                                        <th class="text-center">Trạng thái</th>
                                        @* THÊM CỘT NÀY *@
                                        <th class="text-center">Người xử lý</th>
                                        <th class="text-center">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.ListRequest != null && Model.ListRequest.Any())
                                    {
                                        int count = (Model.CurrentPage - 1) * 10 + 1;
                                        foreach (var r in Model.ListRequest)
                                        {
                                            <tr>
                                                <td class="text-center">@(count++)</td>
                                                <td class="fw-bold">@r.Book?.Gmail</td>
                                                <td><small>@r.Reason</small></td>
                                                <td>@r.RequestDate?.ToString("dd/MM/yyyy")</td>
                                                <td class="text-danger fw-bold">@Model.CalculateRefund(r).ToString("N0") đ</td>
                                                <td class="text-center">
                                                    @if (r.Status == "PENDING")
                                                    {
                                                        <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                                    }
                                                    else if (r.Status == "FINISHED")
                                                    {
                                                        <span class="badge bg-success">Đã duyệt</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger">Đã từ chối</span>
                                                    }
                                                </td>

                                                @* HIỂN THỊ EMAIL NGƯỜI XỬ LÝ TẠI ĐÂY *@
                                                <td class="text-center small text-muted">
                                                    @if (r.Staff != null && r.Staff.StaffNavigation != null)
                                                    {
                                                        @r.Staff.StaffNavigation.Gmail
                                                    }
                                                    else
                                                    {
                                                        <span>---</span>
                                                    }
                                                </td>

                                                <td class="text-center">
                                                    <a asp-page="./RequestCancelDetail" asp-route-id="@r.RequestCancelId" class="btn btn-sm btn-info text-white">
                                                        <i class="fas fa-eye"></i> Xem
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (Model.TotalPages > 1)
                        {
                            <nav class="mt-4">
                                <ul class="pagination justify-content-center">
                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                            <a class="page-link" asp-page="./RequestCancelManage" asp-route-p="@i">@i</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>