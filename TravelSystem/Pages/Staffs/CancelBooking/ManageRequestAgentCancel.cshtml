@page
@model TravelSystem.Pages.Staffs.CancelBooking.ManageRequestAgentCancelModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản lý đơn Agent hủy";
}

<div id="layoutSidenav">

    <div id="layoutSidenav_content">
        <main class="container-fluid px-4">
            <h2 class="mt-4 fw-bold text-danger">Đơn hàng do Đại lý hủy</h2>
            <p class="text-muted small">Danh sách các đơn hàng Agent đã xác nhận hủy (Status 3)</p>

            <div class="card mb-4 shadow-sm border-0">
                <div class="card-body">
                    <form method="get" class="row g-3 mb-4">
                        <div class="col-md-5">
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                                <input type="text" asp-for="Keyword" class="form-control border-start-0" placeholder="Tìm theo email khách hàng hoặc mã đơn...">
                                <button class="btn btn-primary px-4" type="submit">Tìm kiếm</button>
                            </div>
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle border">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center">STT</th>
                                    <th>Mã đơn</th>
                                    <th>Email khách</th>
                                    <th>Lý do hủy</th>
                                    <th class="text-end">Tiền hoàn trả</th>
                                    <th class="text-center">Ngày đặt</th>
                                    <th class="text-center">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.BookingList != null && Model.BookingList.Any())
                                {
                                    int count = (Model.CurrentPage - 1) * 5 + 1;
                                    foreach (var b in Model.BookingList)
                                    {
                                        var cancelInfo = b.RequestCancels.FirstOrDefault();
                                        <tr>
                                            <td class="text-center">@(count++)</td>
                                            <td class="fw-bold">#@b.BookCode</td>
                                            <td>@b.Gmail</td>
                                            <td class="text-muted small italic">
                                                @(cancelInfo != null ? cancelInfo.Reason : b.Note)
                                            </td>
                                            <td class="text-end fw-bold text-danger">@b.TotalPrice?.ToString("N0") đ</td>
                                            <td class="text-center small">@b.BookDate?.ToString("dd/MM/yyyy")</td>
                                            <td class="text-center">
                                                @* Nút xem chi tiết trỏ sang file RequestAgentCancelDetail *@
                                                <a asp-page="./RequestAgentCancelDetail" asp-route-id="@b.BookId"
                                                   class="btn btn-sm btn-outline-info px-3">
                                                    <i class="fas fa-eye me-1"></i> Chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted">Không tìm thấy đơn hàng nào bị đại lý hủy.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-4">
                            <ul class="pagination justify-content-center">
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" asp-page="./ManageRequestAgentCancel" asp-route-p="@i" asp-route-Keyword="@Model.Keyword">@i</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </main>
    </div>
</div>