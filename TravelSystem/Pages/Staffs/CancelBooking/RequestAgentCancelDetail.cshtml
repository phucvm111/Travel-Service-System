@page "{id:int}"
@model TravelSystem.Pages.Staffs.CancelBooking.RequestAgentCancelDetailModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết đơn Agent hủy";
    var b = Model.BookingItem;
    // Lấy thông tin yêu cầu hủy đầu tiên (nếu có)
    var cancelRequest = b.RequestCancels.FirstOrDefault();
}

<div id="layoutSidenav">

    <div id="layoutSidenav_content">
        <main class="container-fluid px-4">
            <div class="d-flex align-items-center mt-4 mb-4">
                <a asp-page="./ManageRequestAgentCancel" class="btn btn-outline-secondary me-3">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
                <h2 class="fw-bold mb-0 text-dark">Thông tin chi tiết đơn hủy</h2>
            </div>

            <div class="row">
                <div class="col-lg-8">
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white py-3 fw-bold text-primary border-bottom">
                            <i class="fas fa-file-invoice me-2"></i>Thông tin đơn hàng
                        </div>
                        <div class="card-body p-4">
                            <div class="row mb-3">
                                <div class="col-sm-4 text-muted small text-uppercase">Mã đơn hàng:</div>
                                <div class="col-sm-8 fw-bold">#@b.BookCode</div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-sm-4 text-muted small text-uppercase">Tên tour:</div>
                                <div class="col-sm-8 fw-bold text-dark">@b.TourDeparture?.Tour?.TourName</div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-sm-4 text-muted small text-uppercase">Ngày khởi hành:</div>
                                <div class="col-sm-8">@b.TourDeparture?.StartDate?.ToString("dd/MM/yyyy")</div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-sm-4 text-muted small text-uppercase">Khách hàng:</div>
                                <div class="col-sm-8">@b.FirstName @b.LastName (@b.Gmail)</div>
                            </div>
                            <hr />
                            <div class="row mb-3 align-items-center">
                                <div class="col-sm-4 text-muted small text-uppercase">Tiền hoàn trả (100%):</div>
                                <div class="col-sm-8 h4 mb-0 text-danger fw-bold">@b.TotalPrice?.ToString("N0") đ</div>
                            </div>
                            <div class="row mb-0">
                                <div class="col-sm-4 text-muted small text-uppercase">Lý do hủy từ Agent:</div>
                                <div class="col-sm-8 bg-light p-3 rounded italic text-secondary">
                                    "@(cancelRequest?.Reason ?? b.Note ?? "Không có lý do chi tiết")"
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 mb-4 text-center">
                        <div class="card-body py-4">
                            <p class="text-muted small text-uppercase mb-2">Trạng thái đơn hàng</p>
                            <span class="badge bg-danger px-4 py-2 rounded-pill">BỊ HỦY BỞI ĐẠI LÝ</span>
                            @if (cancelRequest != null)
                            {
                                <p class="mt-3 text-muted small">Ngày yêu cầu: @cancelRequest.RequestDate?.ToString("dd/MM/yyyy")</p>
                            }
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white py-3 fw-bold text-success border-bottom">
                            <i class="fas fa-briefcase me-2"></i>Đại lý phụ trách
                        </div>
                        <div class="card-body p-4 small">
                            <h6 class="fw-bold mb-1">@b.TourDeparture?.Tour?.TravelAgent?.TravelAgentName</h6>
                            <p class="text-muted mb-0">@b.TourDeparture?.Tour?.TravelAgent?.TravelAgentEmail</p>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>